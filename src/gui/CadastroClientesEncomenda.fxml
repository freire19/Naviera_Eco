<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="600.0" prefWidth="800.0" styleClass="root-financeiro" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.CadastroClientesEncomendaController">
   <top>
      <VBox alignment="CENTER" styleClass="header-panel" BorderPane.alignment="CENTER">
         <children>
            <Label styleClass="title-main-screen" text="Cadastro de Clientes (Encomendas)" />
         </children>
         <padding>
            <Insets bottom="10.0" top="10.0" />
         </padding>
      </VBox>
   </top>
   <center>
      <HBox spacing="20.0" BorderPane.alignment="CENTER" styleClass="main-background">
         <children>
            <ListView fx:id="listViewClientes" prefWidth="400.0" HBox.hgrow="ALWAYS" />
            
            <VBox spacing="10.0" minWidth="300.0" styleClass="content-panel" style="-fx-padding: 15;">
               <children>
                  <Label text="Nome do Cliente:" styleClass="label-bold"/>
                  <TextField fx:id="txtNomeCliente" />
                  
                  <HBox spacing="10.0" alignment="CENTER_RIGHT">
                     <children>
                        <Button fx:id="btnNovo" onAction="#handleNovo" prefWidth="80.0" text="Novo" />
                        <Button fx:id="btnSalvar" onAction="#handleSalvar" prefWidth="80.0" styleClass="button-success" text="Salvar" />
                        <Button fx:id="btnExcluir" onAction="#handleExcluir" prefWidth="80.0" styleClass="button-danger" text="Excluir" />
                     </children>
                     <VBox.margin>
                        <Insets top="10.0" />
                     </VBox.margin>
                  </HBox>
               </children>
            </VBox>
         </children>
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
      </HBox>
   </center>
</BorderPane>
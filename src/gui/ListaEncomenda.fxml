<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane fx:id="rootPane" minHeight="720.0" minWidth="1250.0" prefHeight="750.0" prefWidth="1300.0" styleClass="root-financeiro" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.ListaEncomendaController">
   
   <right>
      <javafx.scene.control.ScrollPane fitToWidth="true" hbarPolicy="NEVER" minWidth="280.0" prefWidth="300.0" maxWidth="320.0" style="-fx-background-color: transparent;" BorderPane.alignment="CENTER">
         <content>
            <VBox spacing="8.0" styleClass="sidebar-panel" style="-fx-padding: 15;">
               <children>
                  <Label text="FILTROS DE BUSCA" styleClass="label-highlight" style="-fx-font-size: 16px;" />
                  <Separator prefWidth="200.0" />
                  
                  <Label text="Viagem:" styleClass="label-small-bold" />
                  <ComboBox fx:id="cmbViagem" maxWidth="1.7976931348623157E308" promptText="Selecione a Viagem" />
                  
                  <Label text="Rota:" styleClass="label-small-bold" />
                  <ComboBox fx:id="cmbFiltroRota" maxWidth="1.7976931348623157E308" promptText="Todas as Rotas" />
                  
                  <Label text="Caixa:" styleClass="label-small-bold" />
                  <ComboBox fx:id="cmbFiltroCaixa" maxWidth="1.7976931348623157E308" promptText="Todos os Caixas" />
                  
                  <Separator prefWidth="200.0" />

                  <Label text="Situação Financeira:" styleClass="label-small-bold" />
                  <VBox spacing="3.0">
                     <children>
                        <RadioButton fx:id="rbPagoTodas" mnemonicParsing="false" selected="true" text="Todos" />
                        <RadioButton fx:id="rbPagoQuitados" mnemonicParsing="false" text="Quitados (Pagos)" style="-fx-text-fill: #059669;" />
                        <RadioButton fx:id="rbPagoAbertos" mnemonicParsing="false" text="Abertos (Falta Pagar)" style="-fx-text-fill: #DC2626;" />
                     </children>
                  </VBox>

                  <Label text="Status de Entrega:" styleClass="label-small-bold" />
                  <VBox spacing="3.0">
                     <children>
                        <RadioButton fx:id="rbEntregueTodas" mnemonicParsing="false" selected="true" text="Todos" />
                        <RadioButton fx:id="rbEntregueSim" mnemonicParsing="false" text="Entregues" style="-fx-text-fill: #047857;" />
                        <RadioButton fx:id="rbEntregueNao" mnemonicParsing="false" text="Pendentes" style="-fx-text-fill: #DC2626;" />
                     </children>
                  </VBox>
                  
                  <Separator prefWidth="200.0" />
                  
                  <Label text="Cliente (Nome ou Sobrenome):" styleClass="label-small-bold" />
                  <TextField fx:id="txtFiltroCliente" promptText="Digite parte do nome..." />
                  
                  <Label text="Nº Encomenda:" styleClass="label-small-bold" />
                  <TextField fx:id="txtFiltroNumeroEncomenda" promptText="Ex: 5" />

                  <Label text="Contém o Produto (Item):" styleClass="label-small-bold" />
                  <TextField fx:id="txtFiltroItem" promptText="Ex: Cimento, Motor..." />
                  
                  <Separator prefWidth="200.0">
                     <VBox.margin>
                        <Insets top="10.0" />
                     </VBox.margin>
                  </Separator>
                  
                  <Button fx:id="btnImprimir" mnemonicParsing="false" prefHeight="45.0" maxWidth="1.7976931348623157E308" style="-fx-background-color: #059669; -fx-text-fill: white; -fx-cursor: hand; -fx-font-weight: bold;" text="IMPRIMIR LISTA">
                     <font>
                        <Font name="System Bold" size="13.0" />
                     </font>
                  </Button>

                  <Button fx:id="btnLimparFiltros" mnemonicParsing="false" prefHeight="45.0" maxWidth="1.7976931348623157E308" style="-fx-background-color: #9e9e9e; -fx-text-fill: white; -fx-cursor: hand;" text="Limpar Filtros">
                     <VBox.margin>
                        <Insets bottom="15.0" />
                     </VBox.margin>
                  </Button>
               </children>
            </VBox>
         </content>
      </javafx.scene.control.ScrollPane>
   </right>

   <center>
      <TableView fx:id="tabelaEncomendas" prefHeight="200.0" prefWidth="200.0" BorderPane.alignment="CENTER">
        <columns>
          <TableColumn fx:id="colNumero" prefWidth="60.0" style="-fx-alignment: CENTER;" text="Nº" />
          <TableColumn fx:id="colRemetente" prefWidth="150.0" text="Remetente" />
          <TableColumn fx:id="colDestinatario" prefWidth="150.0" text="Destinatário" />
          <TableColumn fx:id="colRotaNome" prefWidth="100.0" text="Rota" />
          <TableColumn fx:id="colValorNominal" prefWidth="90.0" style="-fx-alignment: CENTER-RIGHT;" text="Valor Total" />
          <TableColumn fx:id="colValorPago" prefWidth="90.0" style="-fx-alignment: CENTER-RIGHT;" text="Pago" />
          <TableColumn fx:id="colDevedor" prefWidth="90.0" style="-fx-alignment: CENTER-RIGHT;" text="A Receber" />
          <TableColumn fx:id="colDocRecebedor" prefWidth="100.0" text="Doc. Recebedor" />
          <TableColumn fx:id="colStatus" prefWidth="140.0" style="-fx-alignment: CENTER;" text="Status" />
        </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>
   </center>

   <bottom>
      <VBox prefHeight="100.0" minHeight="100.0" maxHeight="100.0" BorderPane.alignment="CENTER">
         <children>
            <HBox alignment="CENTER_LEFT" prefHeight="100.0" minHeight="100.0" spacing="20.0" styleClass="footer-panel" style="-fx-padding: 12 15 12 15;">
               <children>
                  <VBox alignment="CENTER_LEFT" spacing="2.0">
                     <children>
                        <Label text="Qtd. Encomendas" styleClass="label-small-bold" style="-fx-font-size: 11px;"/>
                        <Label fx:id="lblQtdTotal" text="0" styleClass="label-bold" style="-fx-font-size: 16px;" />
                     </children>
                  </VBox>
                  <Separator orientation="VERTICAL" />
                  <VBox alignment="CENTER_LEFT" spacing="2.0">
                     <children>
                        <Label text="Total Lançado" styleClass="label-small-bold" style="-fx-font-size: 11px;"/>
                        <Label fx:id="lblValorTotal" text="R$ 0,00" style="-fx-text-fill: #059669; -fx-font-weight: bold; -fx-font-size: 16px;" />
                     </children>
                  </VBox>
                  <Separator orientation="VERTICAL" />
                  <VBox alignment="CENTER_LEFT" spacing="2.0">
                     <children>
                        <Label text="Total Recebido" styleClass="label-small-bold" style="-fx-font-size: 11px;"/>
                        <Label fx:id="lblTotalRecebido" text="R$ 0,00" style="-fx-text-fill: #059669; -fx-font-weight: bold; -fx-font-size: 16px;" />
                     </children>
                  </VBox>
                  <Separator orientation="VERTICAL" />
                  <VBox alignment="CENTER_LEFT" spacing="2.0">
                     <children>
                        <Label text="A Receber" styleClass="label-small-bold" style="-fx-font-size: 11px;"/>
                        <Label fx:id="lblTotalReceber" text="R$ 0,00" style="-fx-text-fill: #DC2626; -fx-font-weight: bold; -fx-font-size: 18px;" />
                     </children>
                  </VBox>
                  
                  <Region HBox.hgrow="ALWAYS" />
                  
                  <Button fx:id="btnSair" mnemonicParsing="false" onAction="#handleSair" prefHeight="40.0" minWidth="100.0" prefWidth="110.0" styleClass="button-cancel" text="FECHAR">
                     <font>
                        <Font name="System Bold" size="13.0" />
                     </font>
                  </Button>
               </children>
            </HBox>
         </children>
      </VBox>
   </bottom>
</BorderPane>
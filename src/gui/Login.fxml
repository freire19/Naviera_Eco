<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane xmlns="http://javafx.com/javafx/23.0.1" 
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="gui.LoginController"
            prefHeight="250.0" prefWidth="400.0">

    <children>
        <Label layoutX="130.0" layoutY="25.0" text="Tela de Login">
            <font>
                <Font name="Arial Bold" size="18.0" />
            </font>
        </Label>

        <Label layoutX="40.0" layoutY="80.0" text="Usuário:" />
        <ComboBox fx:id="cmbUsuario" layoutX="110.0" layoutY="75.0"
                  prefWidth="220.0" editable="true" />

        <Label layoutX="40.0" layoutY="120.0" text="Senha:" />
        <PasswordField fx:id="txtSenha" layoutX="110.0" layoutY="115.0"
                       prefWidth="220.0" />

        <Button fx:id="btnEntrar" text="Entrar" layoutX="110.0" layoutY="170.0"
                onAction="#handleEntrar" />
        <Button fx:id="btnSair" text="Sair" layoutX="210.0" layoutY="170.0"
                onAction="#handleSair" />
    </children>
</AnchorPane>

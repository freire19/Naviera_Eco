<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="gui.RotasController"
            prefWidth="600" prefHeight="400"
            styleClass="root-financeiro">

    <children>
        <Label layoutX="200" layoutY="14"
               text="Cadastro de Rotas"
               style="-fx-font-size:18; -fx-font-weight:bold;"/>

        <Label layoutX="25" layoutY="60" text="ID:"/>
        <TextField fx:id="txtId"
                   layoutX="70" layoutY="55"
                   prefWidth="80" editable="false"/>

        <Label layoutX="25" layoutY="100" text="Origem:"/>
        <TextField fx:id="txtOrigem"
                   layoutX="80" layoutY="95"
                   prefWidth="200"/>

        <Label layoutX="25" layoutY="140" text="Destino:"/>
        <TextField fx:id="txtDestino"
                   layoutX="85" layoutY="135"
                   prefWidth="200"/>

        <Button fx:id="btnNova" text="Nova Rota"
                layoutX="25" layoutY="180"
                prefWidth="80"/>
        <Button fx:id="btnSalvar" text="Salvar"
                layoutX="110" layoutY="180"
                prefWidth="70"/>
        <Button fx:id="btnEditar" text="Editar"
                layoutX="190" layoutY="180"
                prefWidth="70"/>
        <Button fx:id="btnExcluir" text="Excluir"
                layoutX="270" layoutY="180"
                prefWidth="70"/>

        <TableView fx:id="tabelaRotas"
                   layoutX="25" layoutY="230"
                   prefWidth="550" prefHeight="150">
            <columns>
                <TableColumn fx:id="colId"     text="ID"      prefWidth="70"/>
                <TableColumn fx:id="colOrigem" text="Origem"  prefWidth="200"/>
                <TableColumn fx:id="colDestino" text="Destino" prefWidth="200"/>
            </columns>
        </TableView>
    </children>
</AnchorPane>

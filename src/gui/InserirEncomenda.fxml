<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane fx:id="rootPane" prefHeight="700.0" prefWidth="1100.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.InserirEncomendaController">
   <top>
      <VBox spacing="5.0" styleClass="painel-cabecalho" BorderPane.alignment="CENTER">
         <children>
            <HBox alignment="CENTER_LEFT" spacing="15.0">
               <children>
                  <Button fx:id="btnIniciar" mnemonicParsing="false" onAction="#handleIniciar" style="-fx-background-color: #059669; -fx-text-fill: white; -fx-font-weight: bold;" text="Nova (F2)" />
                  <Button fx:id="btnAbrirLista" mnemonicParsing="false" onAction="#handleAbrirLista" style="-fx-background-color: #6c757d; -fx-text-fill: white;" text="Ver Lista" />
                  <Label alignment="CENTER" maxWidth="1.7976931348623157E308" text="REGISTRAR NOVA ENCOMENDA" textFill="#059669" HBox.hgrow="ALWAYS">
                     <font>
                        <Font name="System Bold" size="22.0" />
                     </font>
                  </Label>
                  <VBox alignment="CENTER_RIGHT">
                     <children>
                        <Label text="N° Encomenda:" textFill="RED">
                           <font>
                              <Font name="System Bold" size="12.0" />
                           </font>
                        </Label>
                        <TextField fx:id="txtNumeroEncomenda" alignment="CENTER" disable="true" prefWidth="100.0" text="1">
                           <font>
                              <Font name="System Bold" size="16.0" />
                           </font>
                        </TextField>
                     </children>
                  </VBox>
               </children>
               <padding>
                  <Insets bottom="10.0" left="15.0" right="15.0" top="10.0" />
               </padding>
            </HBox>
            <Separator prefWidth="200.0" />
         </children>
      </VBox>
   </top>
   
   <center>
      <HBox spacing="20.0" BorderPane.alignment="CENTER">
         <children>
            <VBox minWidth="350.0" prefWidth="450.0" maxWidth="500.0" spacing="12.0">
               <children>
                  <VBox spacing="5.0">
                     <children>
                        <Label text="Remetente:">
                           <font>
                              <Font name="System Bold" size="13.0" />
                           </font>
                        </Label>
                        <ComboBox fx:id="cmbRemetente" editable="true" maxWidth="1.7976931348623157E308" />
                     </children>
                  </VBox>
                  <VBox spacing="5.0">
                     <children>
                        <Label text="Destinatário:">
                           <font>
                              <Font name="System Bold" size="13.0" />
                           </font>
                        </Label>
                        <ComboBox fx:id="cmbDestinatario" editable="true" maxWidth="1.7976931348623157E308" />
                     </children>
                  </VBox>
                  <VBox spacing="5.0">
                     <children>
                        <Label text="Rota:">
                           <font>
                              <Font name="System Bold" size="13.0" />
                           </font>
                        </Label>
                        <ComboBox fx:id="cmbRota" editable="true" maxWidth="1.7976931348623157E308" />
                     </children>
                  </VBox>
                  <VBox spacing="5.0">
                     <children>
                        <Label text="Viagem Atual (Automático):">
                           <font>
                              <Font name="System Bold" size="13.0" />
                           </font>
                        </Label>
                        <TextField fx:id="txtViagemAtual" editable="false">
                           <font>
                              <Font name="System Bold" size="13.0" />
                           </font>
                        </TextField>
                     </children>
                  </VBox>
                  <VBox spacing="5.0">
                     <children>
                        <Label text="Observações:">
                           <font>
                              <Font name="System Bold" size="13.0" />
                           </font>
                        </Label>
                        <TextField fx:id="txtObs" promptText="Ex: Caixa Frágil" />
                     </children>
                  </VBox>
                  
                  <Separator prefWidth="200.0">
                     <VBox.margin>
                        <Insets top="10.0" />
                     </VBox.margin>
                  </Separator>
                  
                  <VBox spacing="8.0" styleClass="info-panel">
                     <children>
                        <Label text="Status da Entrega:" />
                        <TextField fx:id="txtStatusEntrega" editable="false" />
                        <Label text="Nome do Recebedor:" />
                        <TextField fx:id="txtNomeRecebedor" editable="false" />
                        <Label text="RG / CPF / Documento:" />
                        <TextField fx:id="txtNDocumentoRecebedor" editable="false" />
                     </children>
                     <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                     </padding>
                  </VBox>
                  
                  <HBox spacing="10.0" alignment="CENTER">
                      <Button fx:id="btnAudioInput" text="Áudio" prefHeight="35.0" maxWidth="1.7976931348623157E308" HBox.hgrow="ALWAYS" onAction="#handleAudioInput" style="-fx-background-color: #059669; -fx-text-fill: white; -fx-font-weight: bold;"/>
                      <Button fx:id="btnImageInput" text="Foto" prefHeight="35.0" maxWidth="1.7976931348623157E308" HBox.hgrow="ALWAYS" onAction="#handleImageInput" style="-fx-background-color: #059669; -fx-text-fill: white; -fx-font-weight: bold;"/>
                  </HBox>
               </children>
               <padding>
                  <Insets bottom="10.0" left="15.0" right="5.0" top="10.0" />
               </padding>
            </VBox>
            
            <VBox spacing="10.0" HBox.hgrow="ALWAYS">
               <children>
                  <HBox alignment="BOTTOM_LEFT" spacing="10.0" styleClass="input-panel">
                     <children>
                        <VBox>
                           <children>
                              <Label text="Qtd">
                                 <font>
                                    <Font name="System Bold" size="12.0" />
                                 </font>
                              </Label>
                              <TextField fx:id="txtQuantidade" prefWidth="50.0" text="1" />
                           </children>
                        </VBox>
                        <VBox HBox.hgrow="ALWAYS">
                           <children>
                              <Label text="Descrição do Item (Enter busca)">
                                 <font>
                                    <Font name="System Bold" size="12.0" />
                                 </font>
                              </Label>
                              <ComboBox fx:id="cmbDescricao" editable="true" maxWidth="1.7976931348623157E308" />
                           </children>
                        </VBox>
                        <VBox>
                           <children>
                              <Label text="V. Unit.">
                                 <font>
                                    <Font name="System Bold" size="12.0" />
                                 </font>
                              </Label>
                              <TextField fx:id="txtValorUnit" prefWidth="80.0" />
                           </children>
                        </VBox>
                        <VBox>
                           <children>
                              <Label text="Total">
                                 <font>
                                    <Font name="System Bold" size="12.0" />
                                 </font>
                              </Label>
                              <TextField fx:id="txtValorTotal" editable="false" prefWidth="80.0" />
                           </children>
                        </VBox>
                        <Button fx:id="btnAdicionarItem" mnemonicParsing="false" onAction="#handleAdicionarItem" prefHeight="35.0" prefWidth="100.0" style="-fx-background-color: #ff9800; -fx-text-fill: white; -fx-font-weight: bold;" text="Adicionar" />
                     </children>
                     <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                     </padding>
                  </HBox>
                  
                  <TableView fx:id="tableItens" VBox.vgrow="ALWAYS">
                    <columns>
                      <TableColumn fx:id="colQuant" minWidth="50.0" maxWidth="70.0" style="-fx-alignment: CENTER;" text="Quant." />
                      <TableColumn fx:id="colDesc" minWidth="150.0" text="Descrição" />
                      <TableColumn fx:id="colValUnit" minWidth="65.0" maxWidth="95.0" style="-fx-alignment: CENTER_RIGHT;" text="V. Unit." />
                      <TableColumn fx:id="colValTotal" minWidth="80.0" maxWidth="110.0" style="-fx-alignment: CENTER_RIGHT;" text="V. Total" />
                      <TableColumn fx:id="colLocalArmazenamento" minWidth="80.0" maxWidth="200.0" style="-fx-alignment: CENTER;" text="Local" />
                    </columns>
                  </TableView>
               </children>
               <padding>
                  <Insets bottom="10.0" left="5.0" right="15.0" top="10.0" />
               </padding>
            </VBox>
         </children>
      </HBox>
   </center>
   
   <bottom>
      <VBox spacing="0.0" prefHeight="100.0" minHeight="100.0" maxHeight="100.0" BorderPane.alignment="CENTER">
         <children>
            <HBox alignment="CENTER_RIGHT" spacing="15.0" prefHeight="45.0" minHeight="45.0" styleClass="totals-panel">
               <children>
                  <Label text="Total Volumes:">
                     <font>
                        <Font name="System Bold" size="13.0" />
                     </font>
                  </Label>
                  <TextField fx:id="txtTotalVol" alignment="CENTER" editable="false" prefWidth="60.0" text="0">
                     <font>
                        <Font name="System Bold" size="13.0" />
                     </font>
                  </TextField>
                  <Label text="TOTAL A PAGAR:" textFill="#059669">
                     <font>
                        <Font name="System Bold" size="16.0" />
                     </font>
                  </Label>
                  <TextField fx:id="txtTotalAPagar" alignment="CENTER_RIGHT" editable="false" prefWidth="200.0" maxWidth="300.0" text="0.00">
                     <font>
                        <Font name="System Bold" size="18.0" />
                     </font>
                  </TextField>
               </children>
               <padding>
                  <Insets bottom="8.0" left="20.0" right="20.0" top="8.0" />
               </padding>
            </HBox>
            
            <HBox alignment="CENTER_LEFT" spacing="8.0" prefHeight="55.0" minHeight="55.0" styleClass="buttons-panel">
               <children>
                  <Button fx:id="btnSalvar" mnemonicParsing="false" onAction="#handleSalvar" prefHeight="36.0" minWidth="100.0" style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 11px;" text="F3 - FINALIZAR" />
                  
                  <Button fx:id="btnEditar" mnemonicParsing="false" onAction="#handleEditar" prefHeight="36.0" minWidth="60.0" style="-fx-background-color: #007bff; -fx-text-fill: white; -fx-font-size: 11px;" text="Editar" />
                  
                  <Button fx:id="btnExcluir" mnemonicParsing="false" onAction="#handleExcluir" prefHeight="36.0" minWidth="60.0" style="-fx-background-color: #dc3545; -fx-text-fill: white; -fx-font-size: 11px;" text="Excluir" />
                  
                  <Button fx:id="btnImprimir" mnemonicParsing="false" onAction="#handleImprimir" prefHeight="36.0" minWidth="65.0" style="-fx-background-color: #546e7a; -fx-text-fill: white; -fx-font-size: 11px;" text="Imprimir" />
                  
                  <Button fx:id="btnEntregar" mnemonicParsing="false" onAction="#handleEntregar" prefHeight="36.0" minWidth="70.0" style="-fx-background-color: #17a2b8; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 11px;" text="Entregar" />
                  
                  <HBox alignment="CENTER_RIGHT" HBox.hgrow="ALWAYS">
                     <children>
                        <Button fx:id="btnSair" mnemonicParsing="false" onAction="#handleSair" prefHeight="36.0" minWidth="70.0" style="-fx-background-color: #343a40; -fx-text-fill: white; -fx-font-size: 11px;" text="Sair (Esc)" />
                     </children>
                  </HBox>
               </children>
               <padding>
                  <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
               </padding>
            </HBox>
         </children>
      </VBox>
   </bottom>
</BorderPane>
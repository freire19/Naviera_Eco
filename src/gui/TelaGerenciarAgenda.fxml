<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="800.0" styleClass="root-financeiro" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.TelaGerenciarAgendaController">
   <children>
      <VBox spacing="10.0" AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0" AnchorPane.topAnchor="10.0">
         <children>
            <Label text="Gerenciador de Tarefas e Agenda">
               <font>
                  <Font name="System Bold" size="18.0" />
               </font>
            </Label>
            <HBox spacing="10.0" alignment="CENTER_LEFT">
               <children>
                  <CheckBox fx:id="chkOcultarConcluidas" mnemonicParsing="false" onAction="#handleFiltrar" text="Ocultar Concluídas" selected="false"/>
                  <Button mnemonicParsing="false" onAction="#handleAtualizar" text="🔄 Atualizar Lista" />
               </children>
            </HBox>
            <TableView fx:id="tabelaTarefas" prefHeight="200.0" prefWidth="200.0" VBox.vgrow="ALWAYS">
              <columns>
                <TableColumn fx:id="colData" prefWidth="120.0" text="Data" />
                <TableColumn fx:id="colDescricao" prefWidth="450.0" text="Descrição da Tarefa" />
                  <TableColumn fx:id="colConcluida" minWidth="0.0" prefWidth="100.0" text="Concluída?" />
                  <TableColumn fx:id="colAcoes" prefWidth="100.0" text="Ações" />
              </columns>
            </TableView>
         </children>
      </VBox>
   </children>
</AnchorPane>
<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="800.0" styleClass="root-financeiro" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.ListarPassageirosViagemController">
   <children>
      <VBox alignment="TOP_CENTER" layoutX="10.0" layoutY="10.0" spacing="10.0" AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0" AnchorPane.topAnchor="10.0">
         <children>
            <Label text="Lista de Passageiros por Viagem">
               <font>
                  <Font name="System Bold" size="20.0" />
               </font>
            </Label>
            <HBox alignment="CENTER_LEFT" spacing="10.0">
               <children>
                  <Label text="Viagem Ativa:">
                     <font>
                        <Font name="System Bold" size="14.0" />
                     </font>
                  </Label>
                  <Label fx:id="lblViagemAtivaInfo" text="[Nome da Embarcação] - [Data de Saída] - [Horário de Saída]" HBox.hgrow="ALWAYS">
                     <font>
                        <Font size="14.0" />
                     </font>
                  </Label>
               </children>
            </HBox>
            <TableView fx:id="tablePassageirosViagem" VBox.vgrow="ALWAYS">
              <columns>
                <TableColumn fx:id="colOrdem" prefWidth="50.0" text="ORD" />
                <TableColumn fx:id="colNomeCompleto" prefWidth="250.0" text="Nome Completo" />
                <TableColumn fx:id="colDataNascimento" prefWidth="120.0" text="Dt. Nascimento" />
                <TableColumn fx:id="colIdade" prefWidth="60.0" text="Idade" />
                <TableColumn fx:id="colRG" prefWidth="100.0" text="RG" />
                <TableColumn fx:id="colOrigem" prefWidth="100.0" text="Origem" />
                <TableColumn fx:id="colDestino" prefWidth="100.0" text="Destino" />
              </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>
            <HBox alignment="CENTER_RIGHT" spacing="10.0">
               <children>
                  <Button fx:id="btnImprimirLista" onAction="#handleImprimirLista" prefHeight="30.0" prefWidth="120.0" text="Imprimir Lista">
                     <font>
                        <Font name="System Bold" size="14.0" />
                     </font>
                  </Button>
                  <Button fx:id="btnSair" onAction="#handleSair" prefHeight="30.0" prefWidth="75.0" text="Sair">
                     <font>
                        <Font name="System Bold" size="14.0" />
                     </font>
                  </Button>
               </children>
               <VBox.margin>
                  <Insets top="10.0" />
               </VBox.margin>
            </HBox>
         </children>
         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </padding>
      </VBox>
   </children>
</AnchorPane>
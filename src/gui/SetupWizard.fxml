<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane minHeight="480.0" minWidth="680.0" prefHeight="480.0" prefWidth="680.0"
            style="-fx-background-color: #F7FBF9;"
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="gui.SetupWizardController">
   <children>
      <HBox AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
            AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">
         <children>

            <!-- SIDEBAR -->
            <VBox prefWidth="200.0" spacing="0" style="-fx-background-color: #0F2D24;">
               <children>
                  <VBox alignment="CENTER" spacing="5.0" style="-fx-padding: 25 15 20 15;">
                     <children>
                        <Label text="NAVIERA" textFill="#A7F3D0">
                           <font><Font name="System Bold" size="22.0" /></font>
                        </Label>
                        <Label text="Configuracao Inicial" textFill="#7BA393">
                           <font><Font size="12.0" /></font>
                        </Label>
                     </children>
                  </VBox>
                  <Separator style="-fx-background-color: #059669;" />
                  <VBox spacing="5.0" style="-fx-padding: 20 15 0 15;">
                     <children>
                        <HBox fx:id="stepIndicator1" alignment="CENTER_LEFT" spacing="10.0"
                              style="-fx-padding: 10; -fx-background-color: #059669; -fx-background-radius: 5;">
                           <children>
                              <Label text="1" textFill="white" style="-fx-background-color: #047857; -fx-background-radius: 12; -fx-min-width: 24; -fx-min-height: 24; -fx-alignment: center;">
                                 <font><Font name="System Bold" size="12.0" /></font>
                              </Label>
                              <Label text="Ativacao" textFill="white">
                                 <font><Font name="System Bold" size="12.0" /></font>
                              </Label>
                           </children>
                        </HBox>
                        <HBox fx:id="stepIndicator2" alignment="CENTER_LEFT" spacing="10.0" style="-fx-padding: 10; -fx-background-radius: 5;">
                           <children>
                              <Label text="2" textFill="#7BA393" style="-fx-background-color: #1a3d30; -fx-background-radius: 12; -fx-min-width: 24; -fx-min-height: 24; -fx-alignment: center;">
                                 <font><Font name="System Bold" size="12.0" /></font>
                              </Label>
                              <Label text="Preparando" textFill="#7BA393">
                                 <font><Font size="12.0" /></font>
                              </Label>
                           </children>
                        </HBox>
                        <HBox fx:id="stepIndicator3" alignment="CENTER_LEFT" spacing="10.0" style="-fx-padding: 10; -fx-background-radius: 5;">
                           <children>
                              <Label text="3" textFill="#7BA393" style="-fx-background-color: #1a3d30; -fx-background-radius: 12; -fx-min-width: 24; -fx-min-height: 24; -fx-alignment: center;">
                                 <font><Font name="System Bold" size="12.0" /></font>
                              </Label>
                              <Label text="Pronto!" textFill="#7BA393">
                                 <font><Font size="12.0" /></font>
                              </Label>
                           </children>
                        </HBox>
                     </children>
                  </VBox>
                  <Region VBox.vgrow="ALWAYS" />
                  <VBox alignment="CENTER" spacing="3" style="-fx-padding: 10 15 15 15;">
                     <children>
                        <Label text="Problemas?" textFill="#7BA393"><font><Font size="11.0" /></font></Label>
                        <Label text="(92) 00000-0000" textFill="#A7F3D0"><font><Font name="System Bold" size="11.0" /></font></Label>
                     </children>
                  </VBox>
               </children>
            </VBox>

            <!-- CONTEUDO -->
            <VBox HBox.hgrow="ALWAYS" spacing="0">
               <children>
                  <HBox alignment="CENTER_LEFT" prefHeight="50.0"
                        style="-fx-background-color: white; -fx-border-color: #E6F5ED; -fx-border-width: 0 0 1 0;">
                     <padding><Insets left="25.0" right="25.0" /></padding>
                     <children>
                        <Label fx:id="lblStepTitle" text="Ativar sua empresa" textFill="#0F2D24">
                           <font><Font name="System Bold" size="16.0" /></font>
                        </Label>
                     </children>
                  </HBox>

                  <StackPane fx:id="stepContent" VBox.vgrow="ALWAYS" style="-fx-padding: 30;">

                     <!-- TELA 1: Codigo de ativacao -->
                     <VBox fx:id="step1" spacing="20.0" alignment="CENTER">
                        <children>
                           <VBox spacing="8.0" alignment="CENTER" maxWidth="400">
                              <children>
                                 <Label text="Bem-vindo ao Naviera!" textFill="#0F2D24" alignment="CENTER">
                                    <font><Font name="System Bold" size="18.0" /></font>
                                 </Label>
                                 <Label text="Digite o codigo de ativacao que voce recebeu ao cadastrar sua empresa no site naviera.com.br"
                                        textFill="#546e7a" wrapText="true" alignment="CENTER">
                                    <font><Font size="13.0" /></font>
                                 </Label>
                              </children>
                           </VBox>
                           <VBox spacing="8.0" alignment="CENTER" maxWidth="320">
                              <children>
                                 <Label text="Codigo de Ativacao:" textFill="#0F2D24">
                                    <font><Font name="System Bold" size="13.0" /></font>
                                 </Label>
                                 <TextField fx:id="txtCodigoAtivacao" prefHeight="45.0" alignment="CENTER"
                                            promptText="NAV-0000"
                                            style="-fx-font-size: 20; -fx-font-weight: bold; -fx-alignment: center; -fx-border-color: #059669; -fx-border-radius: 8; -fx-background-radius: 8;" />
                                 <Label fx:id="lblStatusAtivacao" text="" textFill="#DC2626" wrapText="true" alignment="CENTER">
                                    <font><Font size="12.0" /></font>
                                 </Label>
                              </children>
                           </VBox>
                           <Button fx:id="btnAtivar" onAction="#handleAtivar" prefHeight="40.0" prefWidth="200.0"
                                   style="-fx-background-color: #059669; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14; -fx-background-radius: 8;"
                                   text="Ativar">
                              <effect><DropShadow color="#00000033" offsetY="2.0" /></effect>
                              <cursor><Cursor fx:constant="HAND" /></cursor>
                           </Button>
                           <VBox spacing="5.0" alignment="CENTER" style="-fx-padding: 15 0 0 0;">
                              <children>
                                 <Label text="Ainda nao tem um codigo?" textFill="#7BA393"><font><Font size="11.0" /></font></Label>
                                 <Hyperlink fx:id="lnkCadastrar" text="Cadastre sua empresa em naviera.com.br"
                                            textFill="#059669" onAction="#handleAbrirSite">
                                    <font><Font size="11.0" /></font>
                                 </Hyperlink>
                              </children>
                           </VBox>
                        </children>
                     </VBox>

                     <!-- TELA 2: Preparando -->
                     <VBox fx:id="step2" spacing="20.0" alignment="CENTER" visible="false">
                        <children>
                           <VBox spacing="8.0" alignment="CENTER" maxWidth="400">
                              <children>
                                 <Label fx:id="lblNomeEmpresa" text="" textFill="#059669" alignment="CENTER">
                                    <font><Font name="System Bold" size="18.0" /></font>
                                 </Label>
                                 <Label fx:id="lblSetupMsg" text="Preparando seu sistema..."
                                        textFill="#0F2D24" wrapText="true" alignment="CENTER">
                                    <font><Font size="14.0" /></font>
                                 </Label>
                              </children>
                           </VBox>
                           <VBox spacing="8.0" maxWidth="400" alignment="CENTER">
                              <children>
                                 <ProgressBar fx:id="progressSetup" prefHeight="18.0" prefWidth="400.0"
                                              progress="-1.0" style="-fx-accent: #059669;" />
                                 <Label fx:id="lblSetupDetail" text="Verificando seu computador..."
                                        textFill="#7BA393" alignment="CENTER">
                                    <font><Font size="12.0" /></font>
                                 </Label>
                              </children>
                           </VBox>
                           <VBox fx:id="boxErro" spacing="10.0" maxWidth="420" visible="false" managed="false"
                                 style="-fx-background-color: #FEF2F2; -fx-border-color: #DC2626; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 15;">
                              <children>
                                 <Label text="Nao foi possivel configurar o sistema" textFill="#991B1B">
                                    <font><Font name="System Bold" size="13.0" /></font>
                                 </Label>
                                 <Label fx:id="lblErroDetalhe" text="" textFill="#7F1D1D" wrapText="true">
                                    <font><Font size="12.0" /></font>
                                 </Label>
                                 <HBox spacing="10.0">
                                    <children>
                                       <Button fx:id="btnTentarNovamente" onAction="#handleTentarNovamente" text="Tentar novamente"
                                               style="-fx-background-color: #059669; -fx-text-fill: white; -fx-font-weight: bold;">
                                          <cursor><Cursor fx:constant="HAND" /></cursor>
                                       </Button>
                                       <Button fx:id="btnCopiarLog" onAction="#handleCopiarLog" text="Copiar log para suporte"
                                               style="-fx-background-color: #E6F5ED; -fx-text-fill: #3D6B56;">
                                          <cursor><Cursor fx:constant="HAND" /></cursor>
                                       </Button>
                                    </children>
                                 </HBox>
                              </children>
                           </VBox>
                        </children>
                     </VBox>

                     <!-- TELA 3: Pronto -->
                     <VBox fx:id="step3" spacing="20.0" alignment="CENTER" visible="false">
                        <children>
                           <Label text="&#x2713;" textFill="#059669" alignment="CENTER">
                              <font><Font name="System Bold" size="48.0" /></font>
                           </Label>
                           <VBox spacing="8.0" alignment="CENTER" maxWidth="400">
                              <children>
                                 <Label text="Tudo pronto!" textFill="#0F2D24" alignment="CENTER">
                                    <font><Font name="System Bold" size="22.0" /></font>
                                 </Label>
                                 <Label fx:id="lblProntoEmpresa" text="" textFill="#059669" alignment="CENTER">
                                    <font><Font name="System Bold" size="15.0" /></font>
                                 </Label>
                              </children>
                           </VBox>
                           <VBox spacing="6.0" maxWidth="360" alignment="CENTER"
                                 style="-fx-background-color: #E6F5ED; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 20;">
                              <children>
                                 <Label fx:id="lblProntoLogin" text="" textFill="#047857" alignment="CENTER">
                                    <font><Font name="System Bold" size="13.0" /></font>
                                 </Label>
                                 <Label text="Use a senha que voce criou no site." textFill="#3D6B56" alignment="CENTER">
                                    <font><Font size="12.0" /></font>
                                 </Label>
                              </children>
                           </VBox>
                           <Button fx:id="btnIniciar" onAction="#handleIniciar" prefHeight="45.0" prefWidth="220.0"
                                   style="-fx-background-color: #059669; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 15; -fx-background-radius: 8;"
                                   text="Iniciar o Naviera">
                              <effect><DropShadow color="#00000033" offsetY="2.0" /></effect>
                              <cursor><Cursor fx:constant="HAND" /></cursor>
                           </Button>
                        </children>
                     </VBox>

                  </StackPane>
               </children>
            </VBox>

         </children>
      </HBox>
   </children>
</AnchorPane>

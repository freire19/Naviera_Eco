<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="900.0" styleClass="root-financeiro" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.TabelaPrecoFreteController">
   <children>
      <HBox alignment="CENTER_LEFT" prefHeight="60.0" spacing="15.0" styleClass="header-panel" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <Label text="Gerenciamento de Fretes" styleClass="title-main-screen">
               <font>
                  <Font name="System Bold" size="22.0" />
               </font>
            </Label>
         </children>
         <padding>
            <Insets left="20.0" />
         </padding>
      </HBox>

      <VBox spacing="15.0" AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0" AnchorPane.topAnchor="70.0">
         <children>
            
            <VBox spacing="10.0" styleClass="content-panel" style="-fx-padding: 15;">
               <children>
                  <HBox alignment="CENTER_LEFT">
                     <children>
                        <Label text="Adicionar / Editar Item" styleClass="label-highlight">
                           <font>
                              <Font name="System Bold" size="14.0" />
                           </font>
                        </Label>
                        <Region HBox.hgrow="ALWAYS" />
                        <Label fx:id="lblStatus" text="Modo: Inserção" styleClass="label-subtitle">
                           <font>
                              <Font name="System Italic" size="12.0" />
                           </font>
                        </Label>
                     </children>
                  </HBox>
                  <Separator />
                  
                  <HBox alignment="CENTER_LEFT" spacing="15.0">
                     <children>
                        <VBox HBox.hgrow="ALWAYS">
                           <children>
                              <Label text="Descrição do Item:" styleClass="label-bold" />
                              <TextField fx:id="txtDescricao" promptText="Ex: Cimento, Arroz, Mudança..." />
                           </children>
                        </VBox>
                        
                        <VBox prefWidth="150.0">
                           <children>
                              <Label text="Preço Normal (R$):" styleClass="label-bold" style="-fx-text-fill: #0d47a1;" />
                              <TextField fx:id="txtPrecoNormal" promptText="0,00" alignment="CENTER_RIGHT" />
                           </children>
                        </VBox>
                        
                        <VBox prefWidth="150.0">
                           <children>
                              <Label text="Preço c/ Desc. (R$):" styleClass="label-bold" style="-fx-text-fill: #2e7d32;" />
                              <TextField fx:id="txtPrecoDesconto" promptText="0,00" alignment="CENTER_RIGHT" />
                           </children>
                        </VBox>
                     </children>
                  </HBox>
                  
                  <HBox alignment="CENTER_RIGHT" spacing="10.0">
                     <children>
                        <Button fx:id="btnNovo" onAction="#handleNovo" prefHeight="35.0" prefWidth="110.0" text="Novo (+)" />
                        <Button fx:id="btnSalvar" defaultButton="true" onAction="#handleSalvar" prefHeight="35.0" prefWidth="120.0" styleClass="button-success" text="SALVAR" />
                        <Button fx:id="btnExcluir" onAction="#handleExcluir" prefHeight="35.0" prefWidth="100.0" styleClass="button-danger" text="Excluir" />
                     </children>
                     <VBox.margin>
                        <Insets top="5.0" />
                     </VBox.margin>
                  </HBox>
               </children>
            </VBox>

            <VBox VBox.vgrow="ALWAYS">
               <children>
                  <HBox alignment="CENTER_LEFT">
                     <children>
                        <Label text="Itens Cadastrados no Sistema:" styleClass="label-subtitle">
                           <font>
                              <Font name="System Bold" size="12.0" />
                           </font>
                        </Label>
                        <Region HBox.hgrow="ALWAYS" />
                        <Button fx:id="btnImprimir" onAction="#handleImprimirRelatorio" styleClass="button-primary" text="Imprimir Tabela" />
                     </children>
                     <VBox.margin>
                        <Insets bottom="5.0" />
                     </VBox.margin>
                  </HBox>
                  
                  <TableView fx:id="tabelaItens" VBox.vgrow="ALWAYS" style="-fx-font-size: 14px;">
                    <columns>
                      <TableColumn fx:id="colDescricao" prefWidth="400.0" text="Descrição / Item" />
                        <TableColumn fx:id="colPrecoNormal" prefWidth="150.0" style="-fx-alignment: CENTER-RIGHT; -fx-font-weight: bold; -fx-text-fill: #0d47a1;" text="Preço Normal" />
                        <TableColumn fx:id="colPrecoDesconto" prefWidth="150.0" style="-fx-alignment: CENTER-RIGHT; -fx-font-weight: bold; -fx-text-fill: #2e7d32;" text="Preço Desconto" />
                    </columns>
                     <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                     </columnResizePolicy>
                  </TableView>
               </children>
            </VBox>
            
            <HBox alignment="CENTER_RIGHT">
               <children>
                  <Button fx:id="btnSair" onAction="#handleSair" prefHeight="40.0" prefWidth="100.0" styleClass="button-cancel" text="SAIR" />
               </children>
            </HBox>
            
         </children>
      </VBox>
   </children>
</AnchorPane>
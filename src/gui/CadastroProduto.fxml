<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="gui.CadastroProdutoController"
            prefWidth="600.0" prefHeight="500.0">

    <children>
        <VBox spacing="10.0" AnchorPane.topAnchor="10" AnchorPane.leftAnchor="10"
              AnchorPane.rightAnchor="10" AnchorPane.bottomAnchor="10">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>

            <Label text="Cadastro de Itens" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

            <TabPane fx:id="tabPane" prefHeight="440.0" prefWidth="580.0">
                <tabs>

                    <!-- Aba de Itens de Frete -->
                    <Tab text="Itens de Frete">
                        <VBox spacing="8.0" padding="10">
                            <!-- Formulário de Cadastro -->
                            <HBox spacing="10">
                                <VBox spacing="4">
                                    <Label text="Nome do Item:"/>
                                    <TextField fx:id="txtNomeFrete" promptText="Ex: SC DE BANANA"/>
                                </VBox>
                                <VBox spacing="4">
                                    <Label text="Descrição:"/>
                                    <TextField fx:id="txtDescFrete" promptText="Ex: sacola"/>
                                </VBox>
                            </HBox>

                            <HBox spacing="10">
                                <VBox spacing="4">
                                    <Label text="Unidade de Medida:"/>
                                    <TextField fx:id="txtUnidFrete" promptText="Ex: kg"/>
                                </VBox>
                                <VBox spacing="4">
                                    <Label text="Preço Normal (R$):"/>
                                    <TextField fx:id="txtPrecoNormalFrete" promptText="Ex: 12,50"/>
                                </VBox>
                                <VBox spacing="4">
                                    <Label text="Preço com Desconto (R$):"/>
                                    <TextField fx:id="txtPrecoDescFrete" promptText="Ex: 10,00"/>
                                </VBox>
                                <Button fx:id="btnSalvarFrete" text="Salvar" styleClass="button-primary"
                                        prefHeight="40"/>
                            </HBox>

                            <!-- Tabela de Itens de Frete -->
                            <TableView fx:id="tableFrete" VBox.vgrow="ALWAYS">
                                <columns>
                                    <TableColumn fx:id="colNomeFrete"      text="Nome"              prefWidth="120"/>
                                    <TableColumn fx:id="colDescFrete"      text="Descrição"         prefWidth="160"/>
                                    <TableColumn fx:id="colUnidFrete"      text="Unidade"           prefWidth="80"/>
                                    <TableColumn fx:id="colPrecoNormFrete" text="Preço Normal (R$)" prefWidth="100"/>
                                    <TableColumn fx:id="colPrecoDescFrete" text="Desconto (R$)"     prefWidth="100"/>
                                </columns>
                                <columnResizePolicy>
                                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                                </columnResizePolicy>
                            </TableView>
                        </VBox>
                    </Tab>

                    <!-- Aba de Itens de Encomenda -->
                    <Tab text="Itens de Encomenda">
                        <VBox spacing="8.0" padding="10">
                            <!-- Formulário de Cadastro -->
                            <HBox spacing="10">
                                <VBox spacing="4">
                                    <Label text="Nome do Item:"/>
                                    <TextField fx:id="txtNomeEnc" promptText="Ex: Caixa Plástica"/>
                                </VBox>
                                <VBox spacing="4">
                                    <Label text="Descrição:"/>
                                    <TextField fx:id="txtDescEnc" promptText="Ex: 50L"/>
                                </VBox>
                            </HBox>

                            <HBox spacing="10">
                                <VBox spacing="4">
                                    <Label text="Unidade de Medida:"/>
                                    <TextField fx:id="txtUnidEnc" promptText="Ex: un"/>
                                </VBox>
                                <VBox spacing="4">
                                    <Label text="Preço Padrão (R$):"/>
                                    <TextField fx:id="txtPrecoEnc" promptText="Ex: 5,00"/>
                                </VBox>
                                <Button fx:id="btnSalvarEnc" text="Salvar" styleClass="button-primary"
                                        prefHeight="40"/>
                            </HBox>

                            <!-- Tabela de Itens de Encomenda -->
                            <TableView fx:id="tableEncomenda" VBox.vgrow="ALWAYS">
                                <columns>
                                    <TableColumn fx:id="colNomeEnc"   text="Nome"      prefWidth="150"/>
                                    <TableColumn fx:id="colDescEnc"   text="Descrição" prefWidth="200"/>
                                    <TableColumn fx:id="colUnidEnc"   text="Unidade"   prefWidth="80"/>
                                    <TableColumn fx:id="colPrecoEnc"  text="Preço (R$)"prefWidth="100"/>
                                </columns>
                                <columnResizePolicy>
                                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                                </columnResizePolicy>
                            </TableView>
                        </VBox>
                    </Tab>

                </tabs>
            </TabPane>

            <HBox alignment="CENTER_RIGHT">
                <Button fx:id="btnFecharProduto" text="Fechar" prefWidth="80"/>
            </HBox>
        </VBox>
    </children>
</AnchorPane>

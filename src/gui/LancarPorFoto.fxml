<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="gui.LancarPorFotoController"
      spacing="12" prefWidth="780" prefHeight="640">
    <padding>
        <Insets top="18" right="20" bottom="18" left="20"/>
    </padding>

    <Label fx:id="lblTitulo" text="Lançar por Foto (OCR)" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
    <Label text="Envie uma foto do documento. O servidor extrai o texto e devolve os dados estruturados." style="-fx-font-size: 12px;"/>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Tipo:" style="-fx-font-weight: bold;"/>
        <ComboBox fx:id="cbTipo" prefWidth="180"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label text="Nº Nota Fiscal (opcional):"/>
        <TextField fx:id="txtNumNf" prefWidth="150" promptText="ex: 12345"/>
    </HBox>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Button fx:id="btnEscolher" text="📷 Selecionar Foto" onAction="#handleEscolherFoto"/>
        <Label fx:id="lblArquivo" text="nenhum arquivo selecionado" style="-fx-font-style: italic;"/>
    </HBox>

    <ImageView fx:id="preview" fitWidth="380" fitHeight="260" preserveRatio="true"/>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Button fx:id="btnProcessar" text="🚀 Processar OCR" onAction="#handleProcessar" disable="true" style="-fx-background-color: #10B981; -fx-text-fill: white; -fx-font-weight: bold;"/>
        <ProgressIndicator fx:id="progress" visible="false" prefWidth="24" prefHeight="24"/>
        <Label fx:id="lblStatus" text=""/>
    </HBox>

    <Label text="Resposta do OCR:" style="-fx-font-weight: bold; -fx-padding: 6 0 0 0;"/>
    <TextArea fx:id="txtResultado" editable="false" wrapText="true" prefRowCount="12" VBox.vgrow="ALWAYS"/>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Fechar" onAction="#handleFechar"/>
    </HBox>
</VBox>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600" prefWidth="800" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.RelatorioPassagemController">
    <children>
        <Label layoutX="288.0" layoutY="14.0" text="Relatório de Passagem">
            <font>
                <Font size="18.0" />
            </font>
        </Label>

        <Label layoutX="20.0" layoutY="60.0" text="Período:" />
        <Label layoutX="20.0" layoutY="84.0" text="Inicial:" />
        <DatePicker fx:id="dpInicial" layoutX="57.0" layoutY="80.0" />

        <Label layoutX="382.0" layoutY="80.0" text="Final:" />
        <DatePicker fx:id="dpFinal" layoutX="418.0" layoutY="77.0" />

        <Button fx:id="btnGerar" layoutX="645.0" layoutY="78.0" onAction="#handleGerarRelatorio" text="Gerar Relatório" />

        <Label layoutX="20.0" layoutY="120.0" text="Total Vendido:" />
        <TextField fx:id="txtTotalVendido" editable="false" layoutX="99.0" layoutY="115.0" prefHeight="26.0" prefWidth="149.0" />

        <Label layoutX="250.0" layoutY="120.0" text="Recebido:" />
        <TextField fx:id="txtRecebido" editable="false" layoutX="303.0" layoutY="115.0" prefHeight="26.0" prefWidth="134.0" />

        <Label layoutX="440.0" layoutY="120.0" text="Descontos:" />
        <TextField fx:id="txtDescontos" editable="false" layoutX="510.0" layoutY="115.0" prefHeight="26.0" prefWidth="126.0" />

        <Button fx:id="btnImprimirRel" layoutX="646.0" layoutY="115.0" onAction="#handleImprimirRel" prefHeight="26.0" prefWidth="96.0" text="Imprimir" />
    </children>
</AnchorPane>

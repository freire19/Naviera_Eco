<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane fx:id="rootPane" style="-fx-background-color: #F7FBF9;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.VenderPassagemController">
   
   <top>
      <VBox style="-fx-background-color: #047857; -fx-border-color: #404040; -fx-border-width: 0 0 1 0;" BorderPane.alignment="CENTER">
         <children>
            <HBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-padding: 6 10 6 10;">
               <children>
                  <Button fx:id="btnNovo" mnemonicParsing="false" onAction="#handleNovo" prefHeight="45.0" prefWidth="130.0"
                          style="-fx-background-color: #059669; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 4;"
                          text="NOVO (F2)" />
                  
                  <Label maxWidth="1.7976931348623157E308" text="EMISSÃO DE PASSAGENS" textFill="#cccccc" HBox.hgrow="ALWAYS">
                     <font>
                        <Font name="System Bold" size="16.0" />
                     </font>
                     <padding>
                        <Insets left="10.0" />
                     </padding>
                  </Label>
                  
                  <HBox alignment="CENTER_RIGHT" spacing="5.0" style="-fx-background-color: rgba(255,255,255,0.2); -fx-padding: 3 10 3 10; -fx-background-radius: 3;">
                     <children>
                        <Label text="Nº Frete/Bilhete:" textFill="WHITE">
                           <font>
                              <Font name="System Bold" size="12.0" />
                           </font>
                        </Label>
                        <TextField fx:id="txtNumBilhete" alignment="CENTER" editable="false" prefHeight="26.0" prefWidth="70.0" styleClass="campo-destaque" />
                     </children>
                  </HBox>
               </children>
            </HBox>
         </children>
      </VBox>
   </top>

   <center>
      <VBox spacing="8.0" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="8.0" left="8.0" right="8.0" top="8.0" />
         </padding>
         <children>
            
            <!-- FORMULÁRIO SUPERIOR -->
            <VBox spacing="6.0" styleClass="painel-formulario" style="-fx-padding: 10;">
               <children>
                  
                  <!-- 1ª LINHA -->
                  <HBox spacing="8.0" alignment="BOTTOM_LEFT">
                     <children>
                        <!-- Passageiro -->
                        <VBox spacing="2" HBox.hgrow="ALWAYS">
                           <Label text="Passageiro (Nome Completo):" textFill="#424242">
                              <font>
                                 <Font name="System Bold" size="11.0" />
                              </font>
                           </Label>
                           <ComboBox fx:id="cmbPassageiroAuto" editable="true" maxWidth="Infinity" promptText="Digite o nome do passageiro..." />
                        </VBox>

                        <!-- Nº Documento -->
                        <VBox spacing="2" prefWidth="150.0">
                           <Label text="N° Documento:" textFill="#424242">
                              <font>
                                 <Font name="System Bold" size="11.0" />
                              </font>
                           </Label>
                           <TextField fx:id="txtNumeroDoc" maxWidth="Infinity" />
                        </VBox>

                        <!-- Tipo Doc -->
                        <VBox spacing="2" prefWidth="110.0">
                           <Label text="Tipo Doc:" textFill="#424242">
                              <font>
                                 <Font name="System Bold" size="11.0" />
                              </font>
                           </Label>
                           <ComboBox fx:id="cmbTipoDoc" maxWidth="Infinity" />
                        </VBox>
                        
                        <!-- Nacionalidade -->
                        <VBox spacing="2" prefWidth="150.0">
                           <Label text="Nacionalidade:" textFill="#424242">
                              <font>
                                 <Font name="System Bold" size="11.0" />
                              </font>
                           </Label>
                           <ComboBox fx:id="cmbNacionalidade" maxWidth="Infinity" />
                        </VBox>
                        
                        <!-- Nascimento / Idade (BLOCO COLADO) -->
                        <VBox spacing="2" prefWidth="200.0">
                           <Label text="Nascimento / Idade:" textFill="#424242">
                              <font>
                                 <Font name="System Bold" size="11.0" />
                              </font>
                           </Label>
                           <HBox alignment="CENTER_LEFT" spacing="0" styleClass="h-compound">
                              <children>
                                 <TextField fx:id="txtNascimentoMask" prefWidth="110.0" />
                                 <DatePicker fx:id="dpDataNascimento" prefWidth="0" visible="false" />
                                 <Region prefWidth="1.0" styleClass="splitter" HBox.hgrow="NEVER" />
                                 <TextField fx:id="txtIdade" alignment="CENTER" editable="false" prefWidth="55.0"
                                            styleClass="right-readonly" />
                              </children>
                           </HBox>
                        </VBox>
                        
                        <!-- Sexo -->
                        <VBox spacing="2" prefWidth="90.0">
                           <Label text="Sexo:" textFill="#424242">
                              <font>
                                 <Font name="System Bold" size="11.0" />
                              </font>
                           </Label>
                           <ComboBox fx:id="cmbSexo" maxWidth="Infinity" />
                        </VBox>
                     </children>
                  </HBox>

                  <!-- 2ª LINHA -->
                  <HBox spacing="8.0" alignment="BOTTOM_LEFT">
                     <children>
                        <!-- Viagem Selecionada -->
                        <VBox spacing="2" HBox.hgrow="ALWAYS" minWidth="260.0">
                           <Label text="Viagem Selecionada:" textFill="#059669">
                              <font>
                                 <Font name="System Bold" size="11.0" />
                              </font>
                           </Label>
                           <ComboBox fx:id="cmbViagem" maxWidth="Infinity" styleClass="campo-destaque-viagem" />
                        </VBox>

                        <!-- Data / Hora (BLOCO COLADO) -->
                        <VBox spacing="2" prefWidth="210.0">
                           <Label text="Data / Hora:" textFill="#424242">
                              <font>
                                 <Font name="System Bold" size="11.0" />
                              </font>
                           </Label>
                           <HBox alignment="CENTER_LEFT" spacing="0" styleClass="h-compound">
                              <children>
                                 <TextField fx:id="txtDataViagemMask" editable="false" prefWidth="115.0" />
                                 <DatePicker fx:id="dpDataViagem" prefWidth="0" visible="false" />
                                 <Region prefWidth="1.0" styleClass="splitter" HBox.hgrow="NEVER" />
                                 <TextField fx:id="txtHorario" editable="false" prefWidth="75.0"
                                            styleClass="right-readonly" />
                              </children>
                           </HBox>
                        </VBox>

                        <!-- Rota -->
                        <VBox spacing="2" HBox.hgrow="ALWAYS">
                           <Label text="Rota:" textFill="#424242">
                              <font>
                                 <Font name="System Bold" size="11.0" />
                              </font>
                           </Label>
                           <ComboBox fx:id="cmbRota" maxWidth="Infinity" />
                        </VBox>
                        
                        <!-- Acomodação -->
                        <VBox spacing="2" prefWidth="130.0">
                           <Label text="Acomodação:" textFill="#424242">
                              <font>
                                 <Font name="System Bold" size="11.0" />
                              </font>
                           </Label>
                           <ComboBox fx:id="cmbAcomodacao" maxWidth="Infinity" />
                        </VBox>

                        <!-- Tipo Passagem -->
                        <VBox spacing="2" prefWidth="120.0">
                           <Label text="Tipo Pass.:" textFill="#3D6B56">
                              <font>
                                 <Font name="System Bold" size="11.0" />
                              </font>
                           </Label>
                           <ComboBox fx:id="cmbTipoPassagemAux" maxWidth="Infinity" />
                        </VBox>
                        
                        <!-- Agente -->
                        <VBox spacing="2" prefWidth="140.0">
                           <Label text="Agente:" textFill="#424242">
                              <font>
                                 <Font name="System Bold" size="11.0" />
                              </font>
                           </Label>
                           <ComboBox fx:id="cmbAgenteAux" maxWidth="Infinity" />
                        </VBox>
                        
                        <!-- Requisição -->
                        <VBox spacing="2" prefWidth="70.0">
                           <Label text="Req.:" textFill="#424242">
                              <font>
                                 <Font name="System Bold" size="11.0" />
                              </font>
                           </Label>
                           <TextField fx:id="txtRequisicao" maxWidth="Infinity" />
                        </VBox>
                     </children>
                  </HBox>

                  <Separator />

                  <!-- TARIFAS -->
                  <HBox spacing="15.0" alignment="CENTER_LEFT" styleClass="painel-taxas" style="-fx-padding: 8;">
                     <children>
                        <Label text="TARIFAS:" textFill="#B45309">
                           <font>
                              <Font name="System Bold" size="11.0" />
                           </font>
                        </Label>
                        
                        <HBox spacing="5.0">
                           <VBox spacing="1">
                              <Label text="Alim." textFill="#616161">
                                 <font>
                                    <Font size="10.0" />
                                 </font>
                              </Label>
                              <TextField fx:id="txtAlimentacao" prefWidth="60.0" prefHeight="30.0" styleClass="campo-tarifa" style="-fx-font-size: 12px; -fx-border-color: #bdbdbd; -fx-border-radius: 3;" text="0,00" />
                           </VBox>
                           <VBox spacing="1">
                              <Label text="Transp." textFill="#616161">
                                 <font>
                                    <Font size="10.0" />
                                 </font>
                              </Label>
                              <TextField fx:id="txtTransporte" prefWidth="60.0" prefHeight="30.0" styleClass="campo-tarifa" style="-fx-font-size: 12px; -fx-border-color: #bdbdbd; -fx-border-radius: 3;" text="0,00" />
                           </VBox>
                           <VBox spacing="1">
                              <Label text="Cargas" textFill="#616161">
                                 <font>
                                    <Font size="10.0" />
                                 </font>
                              </Label>
                              <TextField fx:id="txtCargas" prefWidth="60.0" prefHeight="30.0" styleClass="campo-tarifa" style="-fx-font-size: 12px; -fx-border-color: #bdbdbd; -fx-border-radius: 3;" text="0,00" />
                           </VBox>
                           <VBox spacing="1">
                              <Label text="Desc." textFill="#616161">
                                 <font>
                                    <Font size="10.0" />
                                 </font>
                              </Label>
                              <TextField fx:id="txtDescontoTarifa" prefWidth="60.0" prefHeight="30.0" styleClass="campo-tarifa" style="-fx-font-size: 12px; -fx-border-color: #bdbdbd; -fx-border-radius: 3;" text="0,00" />
                           </VBox>
                        </HBox>
                        
                        <Region HBox.hgrow="ALWAYS" />
                        
                        <HBox spacing="12.0" alignment="BOTTOM_RIGHT">
                           <VBox spacing="1" alignment="CENTER_RIGHT">
                              <Label text="Subtotal" textFill="#757575">
                                 <font>
                                    <Font size="10.0" />
                                 </font>
                              </Label>
                              <TextField fx:id="txtTotal" alignment="CENTER_RIGHT" editable="false" prefWidth="90.0" prefHeight="30.0" style="-fx-background-color: transparent; -fx-font-weight: bold; -fx-font-size: 16px; -fx-padding: 0;" text="0,00" />
                           </VBox>
                           
                           <Separator orientation="VERTICAL" />

                           <VBox spacing="1" alignment="CENTER_RIGHT">
                              <Label text="Desconto" textFill="#DC2626">
                                 <font>
                                    <Font size="10.0" />
                                 </font>
                              </Label>
                              <TextField fx:id="txtDesconto" alignment="CENTER_RIGHT" prefWidth="90.0" prefHeight="30.0" style="-fx-text-fill: #DC2626; -fx-border-color: transparent transparent #FEE2E2 transparent; -fx-background-color: transparent; -fx-font-size: 16px; -fx-padding: 0;" text="0,00" />
                           </VBox>

                           <VBox spacing="1" alignment="CENTER_RIGHT" style="-fx-background-color: #059669; -fx-padding: 2 12 2 12; -fx-border-radius: 4;">
                              <Label text="A PAGAR" textFill="#e8f5e9">
                                 <font>
                                    <Font name="System Bold" size="10.0" />
                                 </font>
                              </Label>
                              <TextField fx:id="txtAPagar" alignment="CENTER_RIGHT" editable="false" prefWidth="110.0" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 22px; -fx-padding: 0;" text="0,00" />
                           </VBox>
                           
                           <Button fx:id="btnSalvar" defaultButton="true" mnemonicParsing="false" onAction="#handleSalvar"
                                   prefHeight="45.0" prefWidth="130.0"
                                   style="-fx-background-color: #059669; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px; -fx-cursor: hand;"
                                   text="FINALIZAR (F1)" />
                        </HBox>
                     </children>
                  </HBox>
               </children>
            </VBox>

            <!-- TABELA E PESQUISA -->
            <VBox VBox.vgrow="ALWAYS" spacing="0">
               <children>
                  <HBox alignment="CENTER_LEFT" spacing="5.0" styleClass="barra-pesquisa" style="-fx-padding: 4;">
                     <children>
                        <Label text="Pesquisar:" textFill="#616161">
                           <font>
                              <Font name="System Bold" size="11.0" />
                           </font>
                        </Label>
                        <ComboBox fx:id="cmbPesquisarModo" prefWidth="120.0" />
                        <TextField fx:id="txtPesquisar" promptText="Digite para buscar..." HBox.hgrow="ALWAYS" />
                        <Button fx:id="btnFiltrar" mnemonicParsing="false" onAction="#handleFiltrar" prefHeight="30.0" style="-fx-background-color: #059669; -fx-text-fill: white; -fx-font-size: 11px; -fx-font-weight: bold; -fx-background-radius: 3;" text="BUSCAR" />
                     </children>
                  </HBox>
                  
                  <TableView fx:id="tablePassagens" disable="false" style="-fx-border-color: #bdbdbd; -fx-font-size: 13px; -fx-fixed-cell-size: 40px;" VBox.vgrow="ALWAYS">
                     <columns>
                        <TableColumn fx:id="colNumBilhete" prefWidth="60.0" style="-fx-alignment: CENTER;" text="Bilhete" />
                        <TableColumn fx:id="colPassageiro" prefWidth="280.0" text="Passageiro" />
                        <TableColumn fx:id="colDataNascimento" prefWidth="85.0" style="-fx-alignment: CENTER;" text="Nascimento" />
                        <TableColumn fx:id="colNumeroDoc" prefWidth="100.0" text="Documento" />
                        <TableColumn fx:id="colNacionalidade" prefWidth="90.0" text="Nacionalidade" />
                        <TableColumn fx:id="colOrigem" prefWidth="90.0" text="Origem" />
                        <TableColumn fx:id="colDestino" prefWidth="90.0" text="Destino" />
                        <TableColumn fx:id="colValorTotal" prefWidth="80.0" style="-fx-alignment: CENTER-RIGHT;" text="Total" />
                        <TableColumn fx:id="colValorDesconto" prefWidth="60.0" style="-fx-alignment: CENTER-RIGHT;" text="Desc." />
                        <TableColumn fx:id="colValorPago" prefWidth="80.0" style="-fx-alignment: CENTER-RIGHT;" text="Pago" />
                        <TableColumn fx:id="colValorAPagar" prefWidth="80.0" style="-fx-alignment: CENTER-RIGHT; -fx-font-weight: bold;" text="A Pagar" />
                        <TableColumn fx:id="colDevedor" prefWidth="90.0" style="-fx-alignment: CENTER;" text="Status" />
                     </columns>
                     <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                     </columnResizePolicy>
                  </TableView>
               </children>
            </VBox>
         </children>
      </VBox>
   </center>

   <bottom>
      <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="painel-rodape" style="-fx-padding: 8 10 8 10;" BorderPane.alignment="CENTER">
         <children>
            <Button fx:id="btnEditar" onAction="#handleEditar" prefHeight="45.0" prefWidth="130.0"
                    style="-fx-background-color: #059669; -fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold; -fx-background-radius: 3;"
                    text="EDITAR (F3)" />
            <Button fx:id="btnExcluir" onAction="#handleExcluir" prefHeight="45.0" prefWidth="130.0"
                    style="-fx-background-color: #c62828; -fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold; -fx-background-radius: 3;"
                    text="EXCLUIR (F4)" />
            <Button fx:id="btnCancelar" onAction="#handleCancelar" prefHeight="45.0" prefWidth="130.0"
                    style="-fx-background-color: #546e7a; -fx-text-fill: white; -fx-font-size: 12px; -fx-background-radius: 3;"
                    text="CANCELAR (F5)" />
            <Separator orientation="VERTICAL" />
            <Button fx:id="btnImprimirBilhete" onAction="#handleImprimirBilhete" prefHeight="45.0" prefWidth="130.0"
                    style="-fx-background-color: #059669; -fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold; -fx-background-radius: 3;"
                    text="BILHETE (F6)" />
            <Button fx:id="btnImprimirLista" onAction="#handleImprimirLista" prefHeight="45.0" prefWidth="190.0"
                    style="-fx-background-color: #059669; -fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold; -fx-background-radius: 3;"
                    text="LISTA DE PASSAGEIROS (F7)" />
            <Button fx:id="btnRelatorio" onAction="#handleRelatorio" prefHeight="45.0" prefWidth="130.0"
                    style="-fx-background-color: #059669; -fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold; -fx-background-radius: 3;"
                    text="RELATÓRIO (F8)" />
            <Region HBox.hgrow="ALWAYS" />
            <Label text="Total:" textFill="#616161">
               <font>
                  <Font name="System Bold" size="13.0" />
               </font>
            </Label>
            <TextField fx:id="txtTotalPassageiros" alignment="CENTER" editable="false" prefHeight="30.0" prefWidth="60.0" styleClass="campo-destaque" text="0" />
            <Button fx:id="btnSair" onAction="#handleSair" prefHeight="45.0" prefWidth="110.0"
                    style="-fx-background-color: #37474f; -fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold; -fx-background-radius: 3;"
                    text="SAIR (ESC)" />
         </children>
      </HBox>
   </bottom>
</BorderPane>

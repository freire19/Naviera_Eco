<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane styleClass="root-financeiro" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.ExtratoPassageiroController">
   <top>
      <VBox style="-fx-background-color: #047857; -fx-border-color: #404040; -fx-border-width: 0 0 1 0;" BorderPane.alignment="CENTER">
         <children>
            <HBox alignment="CENTER_LEFT" spacing="10.0">
               <padding>
                  <Insets bottom="15.0" left="20.0" right="20.0" top="15.0" />
               </padding>
               <children>
                  <VBox HBox.hgrow="ALWAYS">
                     <children>
                        <Label text="EXTRATO FINANCEIRO (PASSAGENS)" textFill="#cccccc">
                           <font><Font name="System Bold" size="18.0" /></font>
                        </Label>
                        <Label fx:id="lblNomeClienteTopo" text="SELECIONE UM PASSAGEIRO" textFill="#999999">
                           <font><Font size="14.0" /></font>
                        </Label>
                     </children>
                  </VBox>
                  <Button mnemonicParsing="false" onAction="#imprimirExtrato" styleClass="botao-secundario" text="🖨 IMPRIMIR EXTRATO (A4)">
                     <cursor><Cursor fx:constant="HAND" /></cursor>
                  </Button>
                  <Button mnemonicParsing="false" onAction="#fechar" style="-fx-background-color: #059669; -fx-text-fill: white; -fx-font-weight: bold; -fx-border-color: white; -fx-border-radius: 3;" text="FECHAR">
                     <cursor><Cursor fx:constant="HAND" /></cursor>
                  </Button>
               </children>
            </HBox>
         </children>
      </VBox>
   </top>
   <center>
      <VBox spacing="15.0" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
         <children>
            <HBox alignment="BOTTOM_LEFT" spacing="10.0">
               <children>
                  <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                     <children>
                        <Label text="Pesquisar Passageiro (Selecione ou Digite):">
                           <font><Font name="System Bold" size="12.0" /></font>
                        </Label>
                        <ComboBox fx:id="cmbPassageiro" editable="true" maxWidth="1.7976931348623157E308" prefHeight="35.0" />
                     </children>
                  </VBox>
                  <VBox spacing="5.0">
                     <children>
                        <Label text="Status:">
                           <font><Font name="System Bold" size="12.0" /></font>
                        </Label>
                        <ComboBox fx:id="cmbStatus" prefHeight="35.0" prefWidth="150.0" />
                     </children>
                  </VBox>
                  <Button mnemonicParsing="false" onAction="#buscar" prefHeight="35.0" prefWidth="100.0" style="-fx-background-color: #059669; -fx-text-fill: white; -fx-font-weight: bold;" text="BUSCAR">
                     <cursor><Cursor fx:constant="HAND" /></cursor>
                  </Button>
               </children>
            </HBox>
            <HBox alignment="CENTER" spacing="20.0">
               <children>
                  <VBox alignment="CENTER" prefHeight="80.0" prefWidth="200.0" styleClass="card-info">
                     <children>
                        <Label text="TOTAL DE PASSAGENS" textFill="#546e7a"><font><Font name="System Bold" size="11.0" /></font></Label>
                        <Label fx:id="lblTotalPassagens" text="R$ 0,00" textFill="#37474f"><font><Font name="System Bold" size="18.0" /></font></Label>
                     </children>
                  </VBox>
                  <VBox alignment="CENTER" layoutX="10.0" layoutY="10.0" prefHeight="80.0" prefWidth="200.0" styleClass="card-info">
                     <children>
                        <Label text="TOTAL PAGO" textFill="#546e7a"><font><Font name="System Bold" size="11.0" /></font></Label>
                        <Label fx:id="lblTotalPago" text="R$ 0,00" textFill="#059669"><font><Font name="System Bold" size="18.0" /></font></Label>
                     </children>
                  </VBox>
                  <VBox alignment="CENTER" layoutX="230.0" layoutY="10.0" prefHeight="80.0" prefWidth="200.0" styleClass="painel-alerta" style="-fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 0); -fx-border-radius: 5;">
                     <children>
                        <Label text="DÍVIDA EM ABERTO" textFill="#c62828"><font><Font name="System Bold" size="11.0" /></font></Label>
                        <Label fx:id="lblDivida" text="R$ 0,00" textFill="#c62828"><font><Font name="System Bold" size="18.0" /></font></Label>
                     </children>
                  </VBox>
                  
                  <Button mnemonicParsing="false" onAction="#imprimirSegundaVia" prefHeight="50.0" prefWidth="150.0" styleClass="botao-secundario" style="-fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.2), 3, 0, 0, 2);" text="📄 2ª VIA RECIBO">
                     <cursor><Cursor fx:constant="HAND" /></cursor>
                     <font><Font size="11.0" /></font>
                  </Button>

                  <Button fx:id="btnQuitarTudo" mnemonicParsing="false" onAction="#quitarDividaTotal" prefHeight="50.0" prefWidth="180.0" style="-fx-background-color: #66bb6a; -fx-text-fill: white; -fx-font-weight: bold; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.2), 3, 0, 0, 2);" text="✅ QUITAR DÍVIDA">
                     <cursor><Cursor fx:constant="HAND" /></cursor>
                     <font><Font size="13.0" /></font>
                  </Button>
               </children>
               <VBox.margin><Insets bottom="10.0" top="10.0" /></VBox.margin>
            </HBox>
            
            <TableView fx:id="tabela" stylesheets="@../css/main.css" VBox.vgrow="ALWAYS">
              <columns>
                <TableColumn fx:id="colData" prefWidth="200.0" style="-fx-alignment: CENTER;" text="Data Viagem - Previsão" />
                <TableColumn fx:id="colRota" prefWidth="150.0" style="-fx-alignment: CENTER;" text="Rota" />
                  <TableColumn fx:id="colDescricao" prefWidth="250.0" text="Bilhete / Descrição" />
                  <TableColumn fx:id="colValor" prefWidth="100.0" style="-fx-alignment: CENTER-RIGHT;" text="Valor Total" />
                  <TableColumn fx:id="colPago" prefWidth="100.0" style="-fx-alignment: CENTER-RIGHT;" text="Pago" />
                  <TableColumn fx:id="colSaldo" prefWidth="100.0" style="-fx-alignment: CENTER-RIGHT; -fx-font-weight: bold;" text="Saldo Devedor" />
                  <TableColumn fx:id="colStatus" prefWidth="120.0" style="-fx-alignment: CENTER;" text="Status" />
              </columns>
               <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
            </TableView>
         </children>
      </VBox>
   </center>
</BorderPane>
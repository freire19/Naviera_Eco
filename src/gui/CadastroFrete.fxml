<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="rootPane" prefHeight="760.0" prefWidth="1280.0" styleClass="root-financeiro" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.CadastroFreteController">

    <children>
        <HBox alignment="CENTER_LEFT" prefHeight="40.0" spacing="10.0" styleClass="header-panel" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <padding>
                <Insets left="15.0" right="15.0" />
            </padding>
            <children>
                <Label styleClass="label-header" text="Lançamento de Frete">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font>
                </Label>
                <Region HBox.hgrow="ALWAYS" />
                <Label text="Nº Frete:" styleClass="label-bold">
               <font>
                  <Font name="System Bold" size="14.0" />
               </font></Label>
                <TextField fx:id="txtNumFrete" alignment="CENTER" editable="false" prefHeight="30.0" prefWidth="100.0" promptText="Auto" style="-fx-font-weight: bold;" />
            </children>
        </HBox>

        <VBox spacing="5.0" AnchorPane.bottomAnchor="5.0" AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0" AnchorPane.topAnchor="45.0">
            <children>

                <VBox spacing="5.0" styleClass="content-panel" style="-fx-padding: 5;">
                    <children>
                        <HBox spacing="10.0" alignment="CENTER_LEFT">
                            <children>
                                <VBox HBox.hgrow="ALWAYS">
                                    <Label text="Remetente:" styleClass="label-small-bold" />
                                    <ComboBox fx:id="cbRemetente" maxWidth="Infinity" promptText="Selecione ou Digite..." />
                                </VBox>
                                <VBox HBox.hgrow="ALWAYS">
                                    <Label text="Destinatário:" styleClass="label-small-bold" />
                                    <ComboBox fx:id="cbCliente" maxWidth="Infinity" promptText="Selecione ou Digite..." />
                                </VBox>
                            </children>
                        </HBox>

                        <HBox spacing="10.0" alignment="CENTER_LEFT">
                            <children>
                                <VBox HBox.hgrow="ALWAYS">
                                    <Label text="Rota:" styleClass="label-small-bold" />
                                    <ComboBox fx:id="cbRota" maxWidth="Infinity" />
                                </VBox>
                                
                                <VBox prefWidth="110.0">
                                    <Label text="Data Viagem:" styleClass="label-small-bold" />
                                    <TextField fx:id="txtViagemAtual" editable="false" styleClass="text-field-disabled-custom" />
                                </VBox>
                                
                                <VBox prefWidth="110.0">
                                    <Label text="Emissão:" styleClass="label-small-bold" />
                                    <TextField fx:id="txtSaida" promptText="dd/MM/yyyy" />
                                </VBox>

                                <VBox prefWidth="180.0">
                                    <Label text="Local Transp.:" styleClass="label-small-bold" />
                                    <TextField fx:id="txtLocalTransporte" promptText="Ex: Porão" />
                                </VBox>
                                
                                <VBox prefWidth="180.0">
                                    <Label text="Conferente:" styleClass="label-small-bold" />
                                    <ComboBox fx:id="cbConferente" maxWidth="Infinity" />
                                </VBox>
                                
                                <VBox HBox.hgrow="ALWAYS">
                                    <Label text="Cidade Cobrança:" styleClass="label-small-bold" />
                                    <TextField fx:id="txtCidadeCobranca" />
                                </VBox>
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <Separator />

                <HBox spacing="10.0" prefHeight="70.0">
                   <children>
                      <VBox spacing="2.0" HBox.hgrow="ALWAYS" styleClass="bordered-panel" style="-fx-padding: 5;">
                          <children>
                              <HBox alignment="CENTER_LEFT" spacing="10.0">
                                  <children>
                                      <Label text="Nota Fiscal?" styleClass="label-highlight"><font><Font name="System Bold" size="12.0" /></font></Label>
                                      <RadioButton fx:id="rbSim" text="Sim"><toggleGroup><ToggleGroup fx:id="notaFiscalToggleGroup" /></toggleGroup></RadioButton>
                                      <RadioButton fx:id="rbNao" selected="true" text="Não" toggleGroup="$notaFiscalToggleGroup" />
                                      <Separator orientation="VERTICAL" />
                                      <Button fx:id="btnFotoNota" onAction="#handleFotoNota" style="-fx-font-size: 11px; -fx-padding: 2 8 2 8;" text="📷 Foto" />
                                      <Button fx:id="btnCodXml" onAction="#handleCodXml" style="-fx-font-size: 11px; -fx-padding: 2 8 2 8;" text="📄 XML" />
                                      <Button fx:id="btnAudio" onAction="#handleAudio" style="-fx-font-size: 11px; -fx-padding: 2 8 2 8;" text="🎤 Áudio" />
                                  </children>
                              </HBox>
                              <HBox spacing="10.0" alignment="CENTER_LEFT">
                                  <children>
                                      <VBox HBox.hgrow="ALWAYS"><Label text="Nº Nota:" styleClass="label-small" /><TextField fx:id="txtNumNota" /></VBox>
                                      <VBox HBox.hgrow="ALWAYS"><Label text="Valor (R$):" styleClass="label-small" /><TextField fx:id="txtValorNota" /></VBox>
                                      <VBox HBox.hgrow="ALWAYS"><Label text="Peso (kg):" styleClass="label-small" /><TextField fx:id="txtPesoNota" /></VBox>
                                  </children>
                              </HBox>
                          </children>
                      </VBox>

                      <VBox spacing="2.0" prefWidth="450.0" styleClass="bordered-panel" style="-fx-padding: 5;">
                          <children>
                              <HBox alignment="CENTER_LEFT" spacing="10.0">
                                  <Label text="Observações:" styleClass="label-small-bold"/>
                                  <Region HBox.hgrow="ALWAYS" />
                                  <Label text="Preço:" styleClass="label-small-bold" />
                                  <RadioButton fx:id="rbNormal" selected="true" text="Normal" style="-fx-font-size: 11px;"><toggleGroup><ToggleGroup fx:id="precoToggleGroup" /></toggleGroup></RadioButton>
                                  <RadioButton fx:id="rbComDesconto" text="Desc." toggleGroup="$precoToggleGroup" style="-fx-font-size: 11px;" />
                              </HBox>
                              <TextArea fx:id="txtObs" VBox.vgrow="ALWAYS" wrapText="true" style="-fx-font-size: 11px;" />
                          </children>
                      </VBox>
                   </children>
                </HBox>

                <Separator />

                <VBox spacing="0.0" VBox.vgrow="ALWAYS" styleClass="table-container-border">
                    <children>
                        <HBox spacing="0.0" styleClass="table-header-panel" style="-fx-padding: 0;">
                            <children>
                                <VBox prefWidth="70.0" style="-fx-padding: 5 2 5 5;">
                                    <Label text="Qtd." styleClass="label-small-bold"/>
                                    <TextField fx:id="txtquantidade" alignment="CENTER" promptText="1" />
                                </VBox>
                                
                                <VBox HBox.hgrow="ALWAYS" style="-fx-padding: 5 2 5 0;">
                                    <Label text="Item / Produto" styleClass="label-small-bold"/>
                                    <ComboBox fx:id="cbitem" editable="true" maxWidth="Infinity" promptText="Digite para buscar..." />
                                </VBox>
                                
                                <VBox prefWidth="130.0" style="-fx-padding: 5 2 5 0;">
                                    <Label text="Preço Unit. (R$)" styleClass="label-small-bold"/>
                                    <TextField fx:id="txtpreco" alignment="CENTER_RIGHT" promptText="0,00" />
                                </VBox>
                                
                                <VBox prefWidth="130.0" style="-fx-padding: 5 2 5 0;">
                                    <Label text="Subtotal (R$)" styleClass="label-small-bold"/>
                                    <TextField fx:id="txttotal" alignment="CENTER_RIGHT" editable="false" promptText="0,00" styleClass="text-field-disabled-custom" />
                                </VBox>
                                
                                <VBox alignment="BOTTOM_CENTER" prefWidth="110.0" style="-fx-padding: 5 5 5 0;">
                                    <Button fx:id="btnInserir" maxWidth="Infinity" onAction="#adicionarItemTabela" style="-fx-background-color: #047857; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="ADICIONAR" />
                                </VBox>
                            </children>
                        </HBox>

                        <TableView fx:id="tabelaItens" VBox.vgrow="ALWAYS" style="-fx-font-size: 13px;">
                            <columns>
                                <TableColumn fx:id="colQuantidade" prefWidth="70.0" style="-fx-alignment: CENTER;" text="Qtd" />
                                <TableColumn fx:id="colItem" prefWidth="500.0" text="Descrição do Item" />
                                <TableColumn fx:id="colPreco" prefWidth="130.0" style="-fx-alignment: CENTER-RIGHT;" text="Preço Unit." />
                                <TableColumn fx:id="colTotal" prefWidth="130.0" style="-fx-alignment: CENTER-RIGHT; -fx-font-weight: bold;" text="Subtotal" />
                                </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </children>
                </VBox>

                <HBox alignment="CENTER_LEFT" spacing="10.0" VBox.vgrow="NEVER" styleClass="footer-panel" style="-fx-padding: 5;">
                    <children>
                        <VBox>
                            <Label text="Volumes:" textFill="#666666"><font><Font size="10.0" /></font></Label>
                            <TextField fx:id="txtTotalVol" alignment="CENTER" editable="false" prefWidth="60.0" style="-fx-font-weight: bold;" text="0" />
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <Label text="TOTAL GERAL:" styleClass="label-bold"><font><Font name="System Bold" size="14.0" /></font></Label>
                        <TextField fx:id="txtValorTotalNota" alignment="CENTER_RIGHT" editable="false" prefWidth="180.0" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-background-color: transparent;" styleClass="text-total-destaque" text="R$ 0,00" />
                    </children>
                </HBox>

                <HBox alignment="CENTER_RIGHT" spacing="10.0" style="-fx-padding: 0 0 5 0;">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="8.0" HBox.hgrow="ALWAYS">
                            <children>
                                <Button fx:id="btnNovo" onAction="#handleNovoFrete" prefHeight="35.0" prefWidth="100.0" text="Novo (F1)" />
                                <Button fx:id="btnAlterar" onAction="#handleAlterarFrete" prefHeight="35.0" prefWidth="100.0" text="Alterar (F2)" />
                                <Button fx:id="btnSalvar" onAction="#handleSalvarFrete" prefHeight="35.0" prefWidth="100.0" styleClass="button-success" text="SALVAR (F3)" />
                                <Button fx:id="btnExcluir" onAction="#handleExcluirFrete" prefHeight="35.0" prefWidth="100.0" styleClass="button-danger" text="Excluir (F4)" />
                            </children>
                        </HBox>
                        
                        <Button fx:id="btnListaDeFrete" onAction="#abrirListaFretes" prefHeight="35.0" text="Lista de Fretes (F5)" />
                        <Button fx:id="btnImprimirNota" onAction="#imprimirNotaFretePersonalizada" prefHeight="35.0" text="Imprimir (F6)" />
                        <Button fx:id="btnImprimirEtiqueta" onAction="#handleImprimirEtiqueta" prefHeight="35.0" text="Etiqueta" />
                        <Button fx:id="btnImprimirRecibo" onAction="#imprimirReciboPersonalizado" prefHeight="35.0" text="Recibo" />
                        <Button fx:id="btnSair" cancelButton="true" onAction="#handleSair" prefHeight="40.0" prefWidth="100.0" styleClass="button-cancel" text="SAIR (Esc)" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="gui.CadastroClienteController"
            prefWidth="600.0" prefHeight="400.0"
            styleClass="root-financeiro">

    <VBox spacing="10.0" alignment="TOP_LEFT" styleClass="content-panel" style="-fx-padding: 20;">
        
        <Label text="Cadastro de Cliente" styleClass="title-main-screen" />

        <HBox spacing="10.0">
            <Label text="Razão Social:" minWidth="100.0" styleClass="label-bold"/>
            <TextField fx:id="txtRazaoSocial"
                       promptText="Nome ou Razão Social" prefWidth="200.0"/>
        </HBox>

        <HBox spacing="10.0">
            <Label text="CNPJ:" minWidth="100.0" styleClass="label-bold"/>
            <TextField fx:id="txtCnpj"
                       promptText="CPF ou CNPJ" prefWidth="200.0"/>
        </HBox>

        <HBox spacing="10.0">
            <Label text="Endereço:" minWidth="100.0" styleClass="label-bold"/>
            <TextField fx:id="txtEndereco"
                       promptText="Endereço completo" prefWidth="300.0"/>
        </HBox>

        <HBox spacing="10.0">
            <Label text="Telefone:" minWidth="100.0" styleClass="label-bold"/>
            <TextField fx:id="txtTelefone"
                       promptText="Telefone" prefWidth="150.0"/>
        </HBox>

        <HBox spacing="10.0" alignment="CENTER_RIGHT">
            <Button fx:id="btnSalvar" text="Salvar" styleClass="button-success"/>
            <Button fx:id="btnEditar" text="Editar" disable="true" />
            <Button fx:id="btnFechar" text="Fechar" styleClass="button-cancel"/>
        </HBox>
    </VBox>

</AnchorPane>
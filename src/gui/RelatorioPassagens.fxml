<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane styleClass="root-financeiro" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.RelatorioPassagensController">
   <top>
      <VBox alignment="CENTER" prefHeight="60.0" styleClass="header-panel" BorderPane.alignment="CENTER">
         <children>
            <Label styleClass="title-main-screen" text="Relat&#243;rio Financeiro de Passagens" />
         </children>
      </VBox>
   </top>
   <center>
      <VBox spacing="10.0" BorderPane.alignment="CENTER" styleClass="main-background">
         <children>
            <HBox alignment="CENTER" spacing="30.0">
               <children>
                  <VBox styleClass="dashboard-card">
                     <children>
                        <Label text="Total Vendido" styleClass="label-small-bold" />
                        <Label fx:id="lblTotalVendido" styleClass="dashboard-card-value" text="R$ 0,00" />
                     </children>
                  </VBox>
                  <VBox styleClass="dashboard-card">
                     <children>
                        <Label text="Total Recebido" styleClass="label-small-bold" />
                        <Label fx:id="lblTotalRecebido" styleClass="dashboard-card-value" text="R$ 0,00" />
                     </children>
                  </VBox>
                  <VBox styleClass="dashboard-card">
                     <children>
                        <Label text="Total a Receber" styleClass="label-small-bold" />
                        <Label fx:id="lblTotalAReceber" styleClass="dashboard-card-value" text="R$ 0,00" />
                     </children>
                  </VBox>
               </children>
            </HBox>
            <HBox spacing="20.0" prefHeight="180.0" maxHeight="200.0">
               <children>
                  <VBox fx:id="chartContainer1" alignment="CENTER" HBox.hgrow="ALWAYS" />
                  <VBox fx:id="chartContainer2" alignment="CENTER" HBox.hgrow="ALWAYS" />
               </children>
            </HBox>
            <TableView fx:id="tableRelatorio" VBox.vgrow="ALWAYS">
              <columns>
                <TableColumn fx:id="colBilhete" prefWidth="65.0" text="Bilhete" />
                <TableColumn fx:id="colDataViagem" prefWidth="100.0" text="Data Viagem" />
                <TableColumn fx:id="colRota" prefWidth="160.0" text="Rota" />
                <TableColumn fx:id="colTipoPassagem" prefWidth="110.0" text="Tipo Passagem" />
                <TableColumn fx:id="colAgente" prefWidth="100.0" text="Agente" />
                <TableColumn fx:id="colValorTotal" prefWidth="100.0" text="Valor Total" />
                <TableColumn fx:id="colValorPago" prefWidth="100.0" text="Valor Pago" />
                <TableColumn fx:id="colDevedor" prefWidth="90.0" text="Devedor" />
                <TableColumn fx:id="colFormaPagamento" prefWidth="120.0" text="Forma Pag." />
                <TableColumn fx:id="colCaixa" prefWidth="100.0" text="Caixa" />
              </columns>
               <placeholder>
                  <Label text="Nenhum dado encontrado para os filtros selecionados." />
               </placeholder>
            </TableView>
         </children>
         <padding>
            <Insets bottom="10.0" left="15.0" right="10.0" top="10.0" />
         </padding>
      </VBox>
   </center>
   <right>
      <ScrollPane fitToWidth="true" hbarPolicy="NEVER" prefWidth="260.0" styleClass="sidebar-panel" BorderPane.alignment="CENTER">
         <content>
            <VBox spacing="5.0" style="-fx-padding: 10;">
               <children>
                  <Label styleClass="label-highlight" text="Filtros do Relat&#243;rio" style="-fx-font-size: 15px;" />
                  <Label text="Status Pagamento:" styleClass="label-small-bold" />
                  <ComboBox fx:id="cmbStatusPagamento" maxWidth="Infinity" />
                  <Label text="Per&#237;odo De:" styleClass="label-small-bold" />
                  <DatePicker fx:id="dpDataInicio" maxWidth="Infinity" />
                  <Label text="At&#233;:" styleClass="label-small-bold" />
                  <DatePicker fx:id="dpDataFim" maxWidth="Infinity" />
                  <Label text="Viagem:" styleClass="label-small-bold" />
                  <ComboBox fx:id="cmbViagem" maxWidth="Infinity" />
                  <Label text="Rota:" styleClass="label-small-bold" />
                  <ComboBox fx:id="cmbRota" maxWidth="Infinity" />
                  <Label text="Agente:" styleClass="label-small-bold" />
                  <ComboBox fx:id="cmbAgente" maxWidth="Infinity" />
                  <Label text="Tipo Passagem:" styleClass="label-small-bold" />
                  <ComboBox fx:id="cmbTipoPassagem" maxWidth="Infinity" />
                  <Label text="Forma de Pagamento:" styleClass="label-small-bold" />
                  <ComboBox fx:id="cmbTipoPagamento" maxWidth="Infinity" />
                  <Label text="Caixa:" styleClass="label-small-bold" />
                  <ComboBox fx:id="cmbCaixa" maxWidth="Infinity" />
                  <Region prefHeight="10.0" />
                  <Button fx:id="btnImprimirRelatorio" mnemonicParsing="false" onAction="#handleImprimirRelatorio" prefHeight="36.0" maxWidth="Infinity" styleClass="button-primary" text="Imprimir Relat&#243;rio" />
                  <Button mnemonicParsing="false" onAction="#handleSair" prefHeight="36.0" maxWidth="Infinity" styleClass="button-danger" text="SAIR (ESC)" />
               </children>
            </VBox>
         </content>
      </ScrollPane>
   </right>
</BorderPane>

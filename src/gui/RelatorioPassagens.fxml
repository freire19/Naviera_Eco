<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="720.0" prefWidth="1280.0" styleClass="root-financeiro" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.RelatorioPassagensController">
   <top>
      <VBox alignment="CENTER" prefHeight="80.0" styleClass="header-panel" BorderPane.alignment="CENTER">
         <children>
            <Label styleClass="title-main-screen" text="Relatório Financeiro de Passagens" />
         </children>
      </VBox>
   </top>
   <center>
      <VBox spacing="20.0" BorderPane.alignment="CENTER" styleClass="main-background">
         <children>
            <HBox alignment="CENTER" spacing="30.0">
               <children>
                  <VBox styleClass="dashboard-card">
                     <children>
                        <Label text="Total Vendido" styleClass="label-small-bold" />
                        <Label fx:id="lblTotalVendido" styleClass="dashboard-card-value" text="R$ 0,00" />
                     </children>
                  </VBox>
                  <VBox styleClass="dashboard-card">
                     <children>
                        <Label text="Total Recebido" styleClass="label-small-bold" />
                        <Label fx:id="lblTotalRecebido" styleClass="dashboard-card-value" text="R$ 0,00" />
                     </children>
                  </VBox>
                  <VBox styleClass="dashboard-card">
                     <children>
                        <Label text="Total a Receber" styleClass="label-small-bold" />
                        <Label fx:id="lblTotalAReceber" styleClass="dashboard-card-value" style="-fx-fill: #d32f2f;" text="R$ 0,00" />
                     </children>
                  </VBox>
               </children>
            </HBox>
            <HBox spacing="20.0" VBox.vgrow="ALWAYS">
               <children>
                  <VBox fx:id="chartContainer1" alignment="CENTER" HBox.hgrow="ALWAYS" />
                  <VBox fx:id="chartContainer2" alignment="CENTER" HBox.hgrow="ALWAYS" />
               </children>
            </HBox>
            <TableView fx:id="tableRelatorio" VBox.vgrow="ALWAYS">
              <columns>
                <TableColumn fx:id="colBilhete" prefWidth="75.0" text="Bilhete" />
                <TableColumn fx:id="colDataViagem" prefWidth="110.0" text="Data Viagem" />
                <TableColumn fx:id="colRota" prefWidth="180.0" text="Rota" />
                <TableColumn fx:id="colTipoPassagem" prefWidth="120.0" text="Tipo Passagem" />
                <TableColumn fx:id="colAgente" prefWidth="120.0" text="Agente" />
                <TableColumn fx:id="colValorTotal" prefWidth="110.0" text="Valor Total" />
                <TableColumn fx:id="colValorPago" prefWidth="110.0" text="Valor Pago" />
                <TableColumn fx:id="colDevedor" prefWidth="110.0" text="Devedor" />
                <TableColumn fx:id="colFormaPagamento" prefWidth="140.0" text="Forma Pag." />
                <TableColumn fx:id="colCaixa" prefWidth="120.0" text="Caixa" />
              </columns>
               <placeholder>
                  <Label text="Nenhum dado encontrado para os filtros selecionados." />
               </placeholder>
            </TableView>
         </children>
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
      </VBox>
   </center>
   <right>
      <VBox prefWidth="280.0" spacing="8.0" styleClass="sidebar-panel" BorderPane.alignment="CENTER" style="-fx-padding: 10;">
         <children>
            <Label styleClass="label-highlight" text="Filtros do Relatório" style="-fx-font-size: 16px;" />
            <Label text="Status Pagamento:" styleClass="label-small-bold" />
            <ComboBox fx:id="cmbStatusPagamento" prefWidth="280.0" />
            <Label text="Período De:" styleClass="label-small-bold" />
            <DatePicker fx:id="dpDataInicio" prefWidth="280.0" />
            <Label text="Até:" styleClass="label-small-bold" />
            <DatePicker fx:id="dpDataFim" prefWidth="280.0" />
            <Label text="Viagem:" styleClass="label-small-bold" />
            <ComboBox fx:id="cmbViagem" prefWidth="280.0" />
            <Label text="Rota:" styleClass="label-small-bold" />
            <ComboBox fx:id="cmbRota" prefWidth="280.0" />
            <Label text="Agente:" styleClass="label-small-bold" />
            <ComboBox fx:id="cmbAgente" prefWidth="280.0" />
            <Label text="Tipo Passagem:" styleClass="label-small-bold" />
            <ComboBox fx:id="cmbTipoPassagem" prefWidth="280.0" />
            <Label text="Forma de Pagamento:" styleClass="label-small-bold" />
            <ComboBox fx:id="cmbTipoPagamento" prefWidth="280.0" />
            <Label text="Caixa:" styleClass="label-small-bold" />
            <ComboBox fx:id="cmbCaixa" prefWidth="280.0" />
            <VBox alignment="BOTTOM_CENTER" VBox.vgrow="ALWAYS">
               <children>
                  <Button fx:id="btnImprimirRelatorio" mnemonicParsing="false" onAction="#handleImprimirRelatorio" prefHeight="40.0" prefWidth="280.0" styleClass="button-primary" text="Imprimir Relatório" />
               </children>
            </VBox>
         </children>
      </VBox>
   </right>
</BorderPane>
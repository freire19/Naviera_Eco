<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane styleClass="root-financeiro" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.ExtratoClienteEncomendaController">
   
   <top>
      <VBox spacing="0.0" BorderPane.alignment="CENTER">
         <children>
            <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-background-color: #047857; -fx-padding: 20; -fx-border-color: #404040; -fx-border-width: 0 0 1 0;">
               <children>
                  <VBox>
                     <children>
                        <Label text="EXTRATO FINANCEIRO (ENCOMENDAS)" textFill="#999999">
                           <font><Font name="System Bold" size="12.0" /></font>
                        </Label>
                        <Label fx:id="lblNomeCliente" text="SELECIONE UM CLIENTE" textFill="WHITE">
                           <font><Font name="System Bold" size="28.0" /></font>
                        </Label>
                     </children>
                  </VBox>
                  <Pane HBox.hgrow="ALWAYS" />
                  <Button mnemonicParsing="false" onAction="#imprimir" styleClass="botao-secundario" text="🖨 IMPRIMIR EXTRATO">
                     <font><Font size="13.0" /></font><cursor><Cursor fx:constant="HAND" /></cursor>
                  </Button>
                  <Button fx:id="btnFechar" mnemonicParsing="false" onAction="#fechar" style="-fx-background-color: #059669; -fx-text-fill: white; -fx-font-weight: bold; -fx-border-color: white; -fx-border-radius: 3;" text="FECHAR">
                     <font><Font size="13.0" /></font><cursor><Cursor fx:constant="HAND" /></cursor>
                  </Button>
               </children>
               <effect><DropShadow color="#0000004d" height="10.0" radius="4.5" width="0.0" /></effect>
            </HBox>
            
            <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-padding: 15 20 5 20;">
               <children>
                  <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                     <children>
                        <Label text="Pesquisar Cliente (Destinatário) - Digite para filtrar:" textFill="#546e7a"><font><Font name="System Bold" size="12.0" /></font></Label>
                        <ComboBox fx:id="cmbClientes" editable="true" maxWidth="1.7976931348623157E308" onAction="#pesquisarCliente" promptText="Digite o nome..." style="-fx-font-size: 14px;" />
                     </children>
                  </VBox>
                  
                  <VBox spacing="5.0">
                     <children>
                        <Label text="Status:" textFill="#546e7a"><font><Font name="System Bold" size="12.0" /></font></Label>
                        <ComboBox fx:id="cmbStatus" onAction="#pesquisarCliente" prefWidth="150.0" style="-fx-font-size: 14px;" />
                     </children>
                  </VBox>

                  <Button mnemonicParsing="false" onAction="#pesquisarCliente" style="-fx-background-color: #059669; -fx-text-fill: white; -fx-font-weight: bold;" text="BUSCAR">
                     <cursor><Cursor fx:constant="HAND" /></cursor>
                     <HBox.margin><Insets top="20.0" /></HBox.margin>
                     <font><Font size="13.0" /></font>
                  </Button>
               </children>
            </HBox>
            
            <HBox alignment="CENTER" spacing="20.0" style="-fx-padding: 20;">
               <children>
                  <VBox alignment="CENTER" prefWidth="250.0" styleClass="card-info">
                     <padding><Insets bottom="15.0" top="15.0" /></padding>
                     <children>
                        <Label text="TOTAL DE ENCOMENDAS ENVIADAS" textFill="#757575"><font><Font name="System Bold" size="12.0" /></font></Label>
                        <Label fx:id="lblTotalGeral" text="R$ 0,00" textFill="#cccccc"><font><Font name="System Bold" size="22.0" /></font></Label>
                     </children>
                  </VBox>
                  
                  <VBox alignment="CENTER" prefWidth="200.0" styleClass="card-info">
                     <padding><Insets bottom="15.0" top="15.0" /></padding>
                     <children>
                        <Label text="TOTAL PAGO" textFill="#757575"><font><Font name="System Bold" size="12.0" /></font></Label>
                        <Label fx:id="lblTotalPago" text="R$ 0,00" textFill="#059669"><font><Font name="System Bold" size="22.0" /></font></Label>
                     </children>
                  </VBox>
                  
                  <VBox alignment="CENTER" prefWidth="200.0" styleClass="painel-alerta" style="-fx-background-radius: 5; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 1); -fx-border-width: 2; -fx-border-radius: 5;">
                     <padding><Insets bottom="15.0" top="15.0" /></padding>
                     <children>
                        <Label text="DÍVIDA EM ABERTO" textFill="#c62828"><font><Font name="System Bold" size="12.0" /></font></Label>
                        <Label fx:id="lblTotalDivida" text="R$ 0,00" textFill="#c62828"><font><Font name="System Black" size="24.0" /></font></Label>
                     </children>
                  </VBox>
                  
                  <Button fx:id="btnQuitarTudo" disable="true" mnemonicParsing="false" onAction="#quitarDividaTotal" prefHeight="60.0" style="-fx-background-color: #059669; -fx-text-fill: white; -fx-font-weight: bold; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 5, 0, 0, 1);" text="✅ QUITAR DÍVIDA TOTAL">
                     <font><Font size="14.0" /></font>
                     <cursor><Cursor fx:constant="HAND" /></cursor>
                  </Button>
               </children>
            </HBox>
         </children>
      </VBox>
   </top>
   
   <center>
      <VBox spacing="10.0" style="-fx-padding: 0 20 20 20;">
         <children>
            <TableView fx:id="tabela" style="-fx-border-color: #cfd8dc; -fx-font-size: 14px;" VBox.vgrow="ALWAYS">
              <columns>
                <TableColumn fx:id="colData" prefWidth="200.0" style="-fx-alignment: CENTER;" text="Data Viagem / Previsão" />
                <TableColumn fx:id="colRota" prefWidth="200.0" text="Rota" />
                <TableColumn fx:id="colDescricao" prefWidth="350.0" text="Descrição / Encomenda" />
                  <TableColumn fx:id="colValor" prefWidth="120.0" style="-fx-alignment: CENTER-RIGHT;" text="Valor" />
                  <TableColumn fx:id="colPago" prefWidth="120.0" style="-fx-alignment: CENTER-RIGHT;" text="Pago" />
                  <TableColumn fx:id="colSaldo" prefWidth="120.0" style="-fx-alignment: CENTER-RIGHT; -fx-font-weight: bold;" text="Saldo Devedor" />
                  <TableColumn fx:id="colStatus" prefWidth="120.0" style="-fx-alignment: CENTER;" text="Status" />
              </columns>
               <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
            </TableView>
         </children>
      </VBox>
   </center>
</BorderPane>
<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.CadastroItensController" prefWidth="750" prefHeight="550" styleClass="root-financeiro"> <children>
        <TabPane fx:id="tabPane" layoutX="15" layoutY="15" prefWidth="720" prefHeight="520" tabClosingPolicy="UNAVAILABLE" AnchorPane.topAnchor="10" AnchorPane.bottomAnchor="10" AnchorPane.leftAnchor="10" AnchorPane.rightAnchor="10">
            <tabs>
                <Tab text="Itens de Frete">
                    <AnchorPane>
                        <children>
                            <TableView fx:id="tabelaFrete" layoutX="10" layoutY="10" prefHeight="250" prefWidth="680" AnchorPane.topAnchor="10" AnchorPane.leftAnchor="10" AnchorPane.rightAnchor="10"> <columns>
                                    <TableColumn fx:id="colNomeFrete" text="Nome do Item" prefWidth="260"/>
                                    <TableColumn fx:id="colValorNormal" text="Valor Normal (R$)" prefWidth="120"/>
                                    <TableColumn fx:id="colValorDesconto" text="Valor com Desconto (R$)" prefWidth="150"/>
                                    <TableColumn fx:id="colAtivoFrete" text="Ativo" prefWidth="60"/>
                                </columns>
                            </TableView>

                            <GridPane layoutX="10" layoutY="270" AnchorPane.leftAnchor="10" AnchorPane.rightAnchor="10" AnchorPane.bottomAnchor="60">
                                <columnConstraints>
                                    <ColumnConstraints halignment="RIGHT" hgrow="SOMETIMES" maxWidth="150.0" minWidth="10.0" prefWidth="120.0" />
                                    <ColumnConstraints hgrow="SOMETIMES" maxWidth="1.7976931348623157E308" minWidth="10.0" prefWidth="200.0" />
                                    <ColumnConstraints halignment="RIGHT" hgrow="SOMETIMES" maxWidth="150.0" minWidth="10.0" prefWidth="120.0" />
                                    <ColumnConstraints hgrow="SOMETIMES" maxWidth="1.7976931348623157E308" minWidth="10.0" prefWidth="150.0" />
                                </columnConstraints>
                                <rowConstraints>
                                    <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                    <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                    <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                </rowConstraints>
                                <children>
                                    <Label text="Nome do Item:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                                    <TextField fx:id="txtNomeItem" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                                    <Label text="Valor Normal (R$):" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                                    <TextField fx:id="txtValorNormal" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                                    <Label text="Valor c/ Desconto (R$):" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                                    <TextField fx:id="txtValorDesconto" GridPane.columnIndex="3" GridPane.rowIndex="1" />

                                    <Label text="Ativo:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                                    <CheckBox fx:id="chkAtivo" text="" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                                </children>
                                <padding>
                                    <Insets top="10" right="10" bottom="10" left="10" />
                                </padding>
                            </GridPane>

                            <HBox spacing="10" layoutX="10" layoutY="430" AnchorPane.leftAnchor="10" AnchorPane.bottomAnchor="10">
                                <children>
                                    <Button fx:id="btnNovoFrete" text="Novo" prefWidth="75" onAction="#handleNovoFrete"/>
                                    <Button fx:id="btnEditarFrete" text="Editar" prefWidth="75" onAction="#handleEditarFrete"/>
                                    <Button fx:id="btnExcluirFrete" text="Excluir" prefWidth="75" onAction="#handleExcluirFrete"/>
                                    <Button fx:id="btnSalvarFrete" text="Salvar" prefWidth="75" onAction="#handleSalvarFrete"/>
                                    <Button fx:id="btnCancelarFrete" text="Cancelar" prefWidth="75" onAction="#handleCancelarFrete"/>
                                </children>
                            </HBox>
                        </children>
                    </AnchorPane>
                </Tab>

                <Tab text="Itens de Encomenda">
                    <AnchorPane>
                        <children>
                            <TableView fx:id="tabelaEncomenda" layoutX="10" layoutY="10" prefHeight="350" prefWidth="680" AnchorPane.topAnchor="10" AnchorPane.leftAnchor="10" AnchorPane.rightAnchor="10">
                                <columns>
                                    <TableColumn fx:id="colNomeEncomenda" text="Nome do Item" prefWidth="300"/>
                                    <TableColumn fx:id="colPrecoEncomenda" text="Preço Unitário (R$)" prefWidth="180"/>
                                    <TableColumn fx:id="colAtivoEncomenda" text="Ativo" prefWidth="60"/>
                                </columns>
                            </TableView>
                            <HBox spacing="10" layoutX="10" layoutY="370" AnchorPane.leftAnchor="10" AnchorPane.bottomAnchor="10">
                                <children>
                                    <Button fx:id="btnNovoEncomenda" text="Novo" prefWidth="75"/>
                                    <Button fx:id="btnEditarEncomenda" text="Editar" prefWidth="75"/>
                                    <Button fx:id="btnExcluirEncomenda" text="Excluir" prefWidth="75"/>
                                    <Button fx:id="btnSalvarEncomenda" text="Salvar" prefWidth="75"/>
                                    <Button fx:id="btnCancelarEncomenda" text="Cancelar" prefWidth="75"/>
                                </children>
                            </HBox>
                        </children>
                    </AnchorPane>
                </Tab>
            </tabs>
        </TabPane>
    </children>
</AnchorPane>
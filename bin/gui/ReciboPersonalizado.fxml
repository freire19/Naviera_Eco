<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="800.0" prefWidth="600.0" style="-fx-padding: 20; -fx-background-color: white;" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.ReciboPersonalizadoController">

    <!-- LOGO (se quiser exibir uma imagem) -->
    <ImageView fx:id="imgLogo" fitHeight="80" fitWidth="80" layoutX="20" layoutY="20" />

    <!-- Razão Social, CNPJ, Data -->
    <Label layoutX="206.0" layoutY="20.0" style="-fx-font-size:16; -fx-font-weight:bold;" text="SISTEMA DE EMBARCAÇÃO" />
    <Label fx:id="lblCnpj" layoutX="231.0" layoutY="46.0" prefHeight="18.0" prefWidth="173.0" text="CNPJ: XX.XXX.XXX/XXXX-XX" />
    <Label fx:id="lblDataEmissao" layoutX="263.0" layoutY="64.0" text="Data: 11/09/2024" />

    <!-- Título: RECIBO -->
    <Label layoutX="282.0" layoutY="109.0" style="-fx-font-size:20; -fx-font-weight:bold;" text="RECIBO" />

    <!-- RECEBEMOS DE -->
    <Label layoutX="20" layoutY="160" style="-fx-font-weight:bold;" text="RECEBEMOS DE:" />
    <Label fx:id="lblRecebemosDe" layoutX="150" layoutY="160" text="(nome do cliente ou empresa)" />

    <!-- DESCRIÇÃO -->
    <Label layoutX="20.0" layoutY="178.0" style="-fx-font-weight:bold;" text="DESCRIÇÃO" />
    <TextArea fx:id="txtDescricao" layoutX="20.0" layoutY="198.0" prefHeight="113.0" prefWidth="560" wrapText="true" />

    <!-- VALOR R$ -->
    <Label layoutX="399.0" layoutY="325.0" style="-fx-font-weight:bold;" text="VALOR R$" />
    <TextField fx:id="txtValor" alignment="CENTER_RIGHT" layoutX="460.0" layoutY="317.0" prefHeight="30.0" prefWidth="120.0" style="-fx-font-size:14; -fx-font-weight:bold;" />

    <!-- TOTAL R$ -->
    <Label layoutX="400.0" layoutY="353.0" style="-fx-font-weight:bold; -fx-font-size:16;" text="TOTAL:" />
    <TextField fx:id="txtTotal" alignment="CENTER_RIGHT" layoutX="460.0" layoutY="351.0" prefHeight="40" prefWidth="120" style="-fx-font-size:16; -fx-font-weight:bold;" />

    <!-- FORMA DE PAGAMENTO / OBS -->
    <Label layoutX="20.0" layoutY="402.0" style="-fx-font-weight:bold;" text="FORMA DE PAGAMENTO" />
    <TextArea fx:id="txtFormaPagamento" layoutX="20.0" layoutY="432.0" prefHeight="60" prefWidth="560" wrapText="true" />

    <!-- Botão Imprimir -->
    <Button fx:id="btnImprimirRecibo" layoutX="459.0" layoutY="499.0" prefHeight="40.0" prefWidth="120.0" text="Imprimir Recibo" />

</AnchorPane>

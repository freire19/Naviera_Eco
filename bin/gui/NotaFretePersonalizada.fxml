<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane xmlns="http://javafx.com/javafx/23.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:id="rootPane"
            fx:controller="gui.NotaFretePersonalizadaController"
            prefWidth="500" prefHeight="700"
            styleClass="root-financeiro" style="-fx-padding:10;">

    <Label layoutX="20" layoutY="10" 
           fx:id="lblRemetente" 
           text="Remetente:" />

    <Label layoutX="20" layoutY="30"
           fx:id="lblDestinatario"
           text="Destinatário:" />

    <Label layoutX="20" layoutY="50"
           fx:id="lblConferente"
           text="Conferente:"/>

    <Label layoutX="20" layoutY="70"
           fx:id="lblRota"
           text="Rota:" 
           style="-fx-font-weight:bold;"/>

    <Label layoutX="20" layoutY="90"
           fx:id="lblDataHora"
           text="Data/Hora:" />

    <Label layoutX="20" layoutY="120"
           text="NOTA DE FRETE"
           style="-fx-font-size:16; -fx-font-weight:bold;" />

    <!-- Tabela de 4 colunas -->
    <TableView fx:id="tabelaItens"
               layoutX="20" layoutY="160"
               prefWidth="460" prefHeight="300">
        <columns>
            <TableColumn fx:id="colQuant" text="Quant" prefWidth="60"/>
            <TableColumn fx:id="colItem"  text="Item"  prefWidth="200"/>
            <TableColumn fx:id="colPreco" text="Preço" prefWidth="100"/>
            <TableColumn fx:id="colTotal" text="Total" prefWidth="100"/>
        </columns>
    </TableView>

    <!-- Info Pagamento -->
    <Label layoutX="20" layoutY="480"
           fx:id="lblPagamento"
           text="Pagamento:" />

    <Label layoutX="20" layoutY="505"
           fx:id="lblTotalGeral"
           text="TOTAL: R$ 0,00" 
           style="-fx-font-size:14; -fx-font-weight:bold;" />

    <Label layoutX="20" layoutY="535"
           fx:id="lblDataHoraFinal"
           text="Data/Hora final" />

    <!-- Botão Imprimir -->
    <Button fx:id="btnImprimirNota"
            layoutX="380" layoutY="650"
            text="Imprimir Nota" />
</AnchorPane>

# Banco de dados PostgreSQL
DB_HOST=host.docker.internal
DB_PORT=5432
DB_NAME=naviera_eco
DB_USER=postgres
DB_PASSWORD=sua_senha_aqui

# JWT Secret (min 32 caracteres — gere com: openssl rand -base64 32)
JWT_SECRET=gere-uma-chave-segura-aqui

# Server
SERVER_PORT=8081

# CORS (origens permitidas, separadas por virgula)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8180

# ============================================================
# PRODUCAO — ANTES DE DEPLOY:
#
# 1. Gere senha forte para DB:
#      openssl rand -base64 24
#
# 2. Gere JWT secret:
#      openssl rand -base64 32
#
# 3. Atualize CORS_ORIGINS com o dominio real:
#      CORS_ORIGINS=https://seu-dominio.com
#
# 4. NUNCA commite o .env real — ele esta no .gitignore
# ============================================================
